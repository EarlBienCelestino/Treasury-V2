    $id             = intval($tmp[4]); 
    $data['budget'] = $tmp[5];
    $data['etype']  = $tmp[6];
    
    $this->db->where('code', $data['code']);
    if ($id > 0) {
        $this->db->where('id !=', $id);
    }
    $query = $this->db->get('coa');

    if ($query->num_rows() > 0) {
        echo json_encode(['status' => 'error', 'message' => 'The Account Code ' . $data['code'] . ' already exists!']);
        exit; 
    }

    if($id > 0) { 
        $this->db->where('id', $id)->update('coa', $data); 
    } else { 
        $this->db->insert('coa', $data);
    } 
    
    echo json_encode(['status' => 'success']);
    exit;
}
