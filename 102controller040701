function Save() {  
    // Safely clean output to prevent crashes, and FORCE JSON format
    if (ob_get_length()) ob_clean(); 
    header('Content-Type: application/json');

    $tmp=$_POST['datas']; 
    $id=intval($tmp[0]);     
    $data['cd_acct1']=$tmp[1]; 
    $data['cd_acct2']=$tmp[2]; 
    $data['cd_acct3']=$tmp[3]; 
    $data['cd_acct4']=$tmp[4]; 
    $data['cd_acct5']=$tmp[5]; 
    $data['code']=$tmp[6]; 
    $data['name']=$tmp[7]; 

    // --- DUPLICATE CHECK ---
    $this->db->where('code', $data['code']);
    if ($id > 0) {
        $this->db->where('id !=', $id); 
    }
    $query = $this->db->get('coa');

    if ($query->num_rows() > 0) {
        echo json_encode(array('status' => 'error', 'message' => 'Warning: The Account Code ' . $data['code'] . ' already exists!'));
        exit; 
    }

    if($id>0) { 
        $this->db->where('id',$id)->update('coa',$data); 
    } else { 
        $this->db->insert('coa',$data);
    } 
    
    echo json_encode(array('status' => 'success'));
    exit;
}
    
function save_rec() {
    if (ob_get_length()) ob_clean(); 
