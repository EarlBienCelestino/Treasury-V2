function save_rec() {
    if(confirm("Are you sure you want to save this record?") == true) {
        
        var datas = [
            $("#code").val(),
            $("#name").val(),
            $("#exp").val(),
            $("#active").val(),
            $("#id").val(),
            $("#budget").val(),
            $("#type_").val()
        ];    
        
        $.ajax({
    url: "<?=base_url('102/dashboard/save_rec/')?>",
    method: "POST",
    dataType: "json",
    data: {datas: datas}, 
    success: function(data) {
        console.log("RESPONSE:", data);  
        if(data && data.status === 'error') {
            alert(" DUPLICATE: " + data.message);
        } else {
            alert("✅ Record saved successfully!"); 
            getcoa(1); 
        }
    },
    error: function(xhr) {
        console.log("RAW ERROR:", xhr.responseText);  
        alert("❌ CONNECTION ERROR: " + xhr.statusText);
    }
});
    }
}

