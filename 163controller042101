function eid() {
 
    $xs = $this->input->post('searchTerm');  
    
    $rs = $this->db
        ->select('a.name, a.username, a.id')
        ->from('users as a')
        ->join('futm_apr as b', 'a.id = b.userid', 'left')
        ->join('hr_mf_emp as c','a.id=c.userid')
        ->where('c.active>',0)
        ->where('b.userid IS NULL')
        ->like('concat(a.name, a.username)', $xs)
        ->order_by('a.name')
        ->limit(10)
        ->get()->result_array();

    $data[] = array("id" => 0, "text" => 'Select User');
    foreach($rs as $row){ $data[] = array("id" => $row['id'], "text" => $row['username'] . ' - ' . $row['name']); }

    echo json_encode($data); 
}

function saveAppr(){
    $postData = $_POST['appr'];    $id = $postData['id'];

    if($postData['id'] == 0){        $this->db->insert('futm_apr',$postData);    }    
    else{        $this->db->where('id', $id)->update('futm_apr', $postData);    }
}

