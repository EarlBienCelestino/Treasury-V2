function ddelrec_batch() {
    $id=intval($this->input->post('id'));
    $seqsRaw=$this->input->post('seqs');
    $seqs=$seqsRaw;
    if(!is_array($seqs)){
        $seqs=json_decode((string)$seqsRaw,true);
    }

    if($id<=0){
        echo json_encode(array('ok'=>0,'msg'=>'invalid record'));
        return;
    }

    $hdr=$this->db->where('id',$id)->get('glh')->row();
    if(!$hdr){
        echo json_encode(array('ok'=>0,'msg'=>'record not found'));
        return;
    }
    if(property_exists($hdr,'fin') && intval($hdr->fin)>0){
        echo json_encode(array('ok'=>0,'msg'=>'transaction is finalized'));
        return;
    }
    if(property_exists($hdr,'void') && intval($hdr->void)>0){
        echo json_encode(array('ok'=>0,'msg'=>'transaction is void'));
        return;
    }

    if(!is_array($seqs) || count($seqs)===0){
        echo json_encode(array('ok'=>0,'msg'=>'no records selected'));
        return;
    }

    $clean=array();
    foreach($seqs as $seq){
        $seq=intval($seq);
        if($seq>0){ $clean[$seq]=$seq; }
    }
    $clean=array_values($clean);
    if(count($clean)===0){
        echo json_encode(array('ok'=>0,'msg'=>'no records selected'));
        return;
    }

    $this->db->where('id',$id)->where('sw',1)->where_in('seq',$clean)->delete('gld');
    $cnt=$this->db->affected_rows();
    echo json_encode(array('ok'=>1,'count'=>$cnt));
}

