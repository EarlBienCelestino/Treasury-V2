function add_save() {
    $data=array();
    $particulars=strtoupper(trim((string)$this->input->post('particulars')));
    $no_ref=trim((string)$this->input->post('no_ref'));
    $dt_refdoc=trim((string)$this->input->post('dt_refdoc'));
    $no_refdoc=trim((string)$this->input->post('no_refdoc'));
    $date_ = trim((string)$this->input->post('date_'));

    $no_ref=strtoupper($no_ref);
    $no_refdoc=strtoupper($no_refdoc);

    $missing=array();
    if($particulars===''){ $missing[]='Particulars'; }
    if($no_ref===''){ $missing[]='Voucher No'; }
    if($dt_refdoc===''){ $missing[]='Ref Date'; }
    if($no_refdoc===''){ $missing[]='Ref No'; }

    if(count($missing)>0){
        echo json_encode(array("ok"=>0,"msg"=>"complete all the fields first"));
        return;
    }

    $data['code']=$this->next_jv_code();
    $data['doc_code']=$data['code'];
    if($date_===''){ $date_=date('Y-m-d'); }
    $data['date_']=$date_;
    $data['ty_tran']='03';
    $data['particulars']=$particulars;
    $data['am_dr']=0;
    $data['am_cr']=0;
    $data['no_ref']=$no_ref;
    $data['dt_refdoc']=$dt_refdoc;
    $data['no_refdoc']=$no_refdoc;
    $cancel=$this->input->post('cancel');
    $void=$this->input->post('void');
    $voidVal = ($cancel || $void) ? 1 : 0;
    $data['cancel']=$voidVal ? 1 : 0;
    $data['void']=$voidVal ? 1 : 0;
    if($voidVal){
        $voidBy=$this->current_user_display_name();
        $data['void_by']=($voidBy!=='') ? $voidBy : null;
    }
    
    $this->db->insert('glh',$data);
    $data['id']=$this->db->insert_id();
    
    $data['ok']=1;
    echo json_encode($data);
}

