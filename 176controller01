function save_batch() {
    $id=intval($this->input->post('id'));
    $rowsJson=$this->input->post('rows');

    if($id<=0){
        echo json_encode(array('ok'=>0,'msg'=>'invalid record'));
        return;
    }

    $hdr=$this->db->where('id',$id)->get('glh')->row();
    if(!$hdr){
        echo json_encode(array('ok'=>0,'msg'=>'record not found'));
        return;
    }
    if(property_exists($hdr,'fin') && intval($hdr->fin)>0){
        echo json_encode(array('ok'=>0,'msg'=>'transaction is finalized'));
        return;
    }
    if(property_exists($hdr,'void') && intval($hdr->void)>0){
        echo json_encode(array('ok'=>0,'msg'=>'transaction is void'));
        return;
    }

    $rows=json_decode($rowsJson,true);
    if(!is_array($rows) || count($rows)==0){
        echo json_encode(array('ok'=>0,'msg'=>'no entries to save'));
        return;
    }

    $sum=0;
    $insertRows=array();
    foreach($rows as $row){
        $branch=isset($row['branch_id']) ? intval($row['branch_id']) : 0;
        $coa=isset($row['coa_id']) ? intval($row['coa_id']) : 0;
        $part=isset($row['particulars']) ? strtoupper(trim((string)$row['particulars'])) : '';
        $amt=isset($row['amount']) ? floatval($row['amount']) : 0;

        if($branch<=0 || $coa<=0 || $part==='' || $amt==0){
            continue;
        }
        $sum+=$amt;
        $insertRows[]=array(
            'sw'=>1,
            'id'=>$id,
            'branch'=>$branch,
            'coa'=>$coa,
            'particulars'=>$part,
            'amount'=>$amt
        );
    }

    if(count($insertRows)==0){
        echo json_encode(array('ok'=>0,'msg'=>'no valid entries to save'));
        return;
    }
    if(abs($sum) > 0.0001){
        echo json_encode(array('ok'=>0,'msg'=>'balance must be 0'));
        return;
    }

    $this->db->insert_batch('gld',$insertRows);
    echo json_encode(array('ok'=>1,'count'=>count($insertRows)));
}

