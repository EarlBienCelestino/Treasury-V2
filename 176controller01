    foreach($groups as $gidx=>$group){
        if($gidx>0){
            $rowItems[]='<tr class="section-break"><td colspan="5"></td></tr>';
        }

        $debits=array();
        $credits=array();
        foreach($group as $row){
            $amt=floatval($row->amount);
            if($amt>=0){ $debits[]=$row; }
            else { $credits[]=$row; }
        }
        $ordered=array_merge($debits,$credits);
        $prevCoaKey=null;

        foreach($ordered as $row){
            $coacode='';
            $coaname='';
            $branch='';
            $part='';

            if(intval($row->coa)>0){
                $coar=$this->db->where('id',intval($row->coa))->get('coa')->row();
                if($coar){
                    if(property_exists($coar,'code')){ $coacode=(string)$coar->code; }
                    if(property_exists($coar,'name')){ $coaname=(string)$coar->name; }
                }
            }

            if(intval($row->branch) > 0){
                $br = $this->db->where('id', intval($row->branch))->get('gl_branch')->row();
                if($br){
                    if(property_exists($br, 'cd_branch') && trim((string)$br->cd_branch) !== ''){
                        $branch = trim((string)$br->cd_branch);
                    } else if(property_exists($br, 'code') && trim((string)$br->code) !== ''){
                        $branch = trim((string)$br->code);
                    } else {
                        $branch = '';
                    }
                }
            }

            $amt=floatval($row->amount);

            $part=trim((string)$row->particulars);
            $title=trim($coaname);
            if($title=='' && $part!=''){ $title=$part; $part=''; }
            if($title==''){ $title='Entry '.$row->seq; }

            $coaKey=intval($row->coa);
            $isRepeat=($coaKey>0 && $prevCoaKey!==null && $prevCoaKey===$coaKey);
            $debit='';
            $credit='';
            if($amt>=0){
                $debit=number_format($amt,2);
                $tdebit+=$amt;
            } else {
                $credit=number_format(abs($amt),2);
                $tcredit+=abs($amt);
            }

            $titleHtml='<div class="acct-title">'.htmlspecialchars($title,ENT_QUOTES).'</div>';
            $partHtml='';
            if($part!==''){
                $partHtml='<div class="acct-sub">'.htmlspecialchars($part,ENT_QUOTES).'</div>';
            }

            if(!$isRepeat){
                // Header row (COA line) - no amount shown unless there is no remark part
                $hdrDebit = ($part==='' ? $debit : '');
                $hdrCredit = ($part==='' ? $credit : '');
                $rowItems[]='<tr>'
                    .'<td class="col-title">'.$titleHtml.'</td>'
                    .'<td class="col-code">'.htmlspecialchars($coacode,ENT_QUOTES).'</td>'
                    .'<td class="col-branch">'.htmlspecialchars($branch,ENT_QUOTES).'</td>'
                    .'<td class="col-num">'.($hdrDebit!=='' ? htmlspecialchars($hdrDebit,ENT_QUOTES) : '').'</td>'
                    .'<td class="col-num">'.($hdrCredit!=='' ? htmlspecialchars($hdrCredit,ENT_QUOTES) : '').'</td>'
                    .'</tr>';

                // Remark/detail row (if present)
                if($part!==''){
                    $rowItems[]='<tr>'
                        .'<td class="col-title">'.$partHtml.'</td>'
                        .'<td class="col-code"></td>'
                        .'<td class="col-branch">'.htmlspecialchars($branch,ENT_QUOTES).'</td>'
                        .'<td class="col-num">'.($debit!=='' ? htmlspecialchars($debit,ENT_QUOTES) : '').'</td>'
                        .'<td class="col-num">'.($credit!=='' ? htmlspecialchars($credit,ENT_QUOTES) : '').'</td>'
                        .'</tr>';
                }
            } else {
                // Repeated (detail) rows: show remark + amount
                $rowItems[]='<tr>'
                    .'<td class="col-title">'.$partHtml.'</td>'
                    .'<td class="col-code"></td>'
                    .'<td class="col-branch">'.htmlspecialchars($branch,ENT_QUOTES).'</td>'
                    .'<td class="col-num">'.($debit!=='' ? htmlspecialchars($debit,ENT_QUOTES) : '').'</td>'
                    .'<td class="col-num">'.($credit!=='' ? htmlspecialchars($credit,ENT_QUOTES) : '').'</td>'
                    .'</tr>';
            }

            if($coaKey>0){ $prevCoaKey=$coaKey; } else { $prevCoaKey=null; }
        }
    }

    $totalDebit=number_format($tdebit,2);
    $totalCredit=number_format($tcredit,2);
    $totalRow='<tr class="total-row">'
        .'<td colspan="3" class="total-label">TOTAL</td>'
        .'<td class="col-num">'.htmlspecialchars($totalDebit,ENT_QUOTES).'</td>'
        .'<td class="col-num">'.htmlspecialchars($totalCredit,ENT_QUOTES).'</td>'
        .'</tr>';

    $printBy='';
    if(isset($_SESSION['user_id']) && intval($_SESSION['user_id'])>0){
        $printBy=(string)$this->db->where('id',intval($_SESSION['user_id']))->get('users')->row('name');
    }
    $printedOn=date('m/d/Y h:i:s A');

    $footerHtml='
  <div class="print-footer">
    <div class="signatories">
      <div class="sig">
        <div class="sig-line"></div>
        <div class="sig-name">REMY</div>
      </div>
      <div class="sig">
        <div class="sig-line"></div>
        <div class="sig-name">LOIDA/ ELISE</div>
      </div>
      <div class="sig">
        <div class="sig-line"></div>
        <div class="sig-name">NANCY</div>
      </div>
      <div class="sig">
        <div class="sig-line"></div>
        <div class="sig-name">AC/ RT.</div>
      </div>
    </div>
    <div class="printed">PRINTED AT: <span id="printedOn">'.htmlspecialchars($printedOn,ENT_QUOTES).'</span> PRINTED BY: '.htmlspecialchars($printBy,ENT_QUOTES).'</div>
  </div>';

    $rowsHtml=implode("\n",$rowItems);
    if($rowsHtml!==''){ $rowsHtml.="\n"; }
    $rowsHtml.=$totalRow;

    $pagesHtml='
<div class="page last">
  <div class="header">
    <div class="left">
      <div class="title">JOURNAL VOUCHER ENTRIES</div>
      <div class="company">'.htmlspecialchars(strtoupper($company),ENT_QUOTES).'</div>
    </div>
    <div class="date">'.htmlspecialchars($dispDate,ENT_QUOTES).'</div>
  </div>
  <table>
    <thead>
      <tr>
        <th class="col-title">ACCOUNT TITLE</th>
        <th class="col-code">ACCT. CODE</th>
        <th class="col-branch">BRANCH</th>
        <th class="col-num">DEBIT</th>
        <th class="col-num">CREDIT</th>
      </tr>
    </thead>
    <tbody>
      '.$rowsHtml.'
    </tbody>
  </table>';

    $pagesHtml.=$footerHtml.'
</div>';

    echo '<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>Journal Voucher Entries</title>
<style>
body { font-family: Arial, Helvetica, sans-serif; color: #111; margin: 0; padding: 0; background: #fff; font-size: 12px; line-height: 1.2; }
.page { padding: 0.35in; max-width: 7.5in; margin: 0 auto; box-sizing: border-box; display: flex; flex-direction: column; min-height: 10in; }
.header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 8px; }
.header .left { font-size: 11px; line-height: 1.2; }
.header .title { font-weight: 700; font-size: 24px; letter-spacing: 0.4px; }
.header .company { font-weight: 700; font-size: 18px; margin-top: 2px; }
.header .date { font-size: 16px; font-weight: 700;}
table { width: 100%; border-collapse: collapse; table-layout: fixed; }
thead th { text-align: left; font-size: 11px; padding: 4px 8px; border-top: 1px solid #000; border-bottom: 1px solid #000; letter-spacing: 0.3px; }
tbody td { font-size: 11px; padding: 4px 8px; vertical-align: top; }
.col-num, .col-branch ,.col-code { 
  text-align: right !important; 
  white-space: nowrap; 
  width: 15%; 
}
  
.col-code { width: 18%; }
.col-branch { width: 10%; }
.col-title { width: 57%; overflow: hidden; }
.acct-title {
  font-weight: 700;
  font-size: 14px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.acct-sub {
  font-weight: normal;
  font-size: 12px;
  margin-top: 2px;
  padding-left: 18px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.acct-sub-only { margin-top: 0; }
.section-break td { border-top: 1px solid #000; padding: 2px 0; }
.total-row td { border-top: 1px solid #000; font-weight: 700; padding-top: 6px; }
