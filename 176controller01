    $tmp=$_POST['datas'];
    $id=intval($tmp[0]);
    $fld=isset($tmp[1]) ? $tmp[1] : '';
    $val=isset($tmp[2]) ? $tmp[2] : '';

    $upperFields=array('particulars','no_ref','no_refdoc');
    if(in_array($fld,$upperFields,true)){
        $val=strtoupper(trim((string)$val));
    }

    if($fld==='void'){
        $hdr=$this->db->where('id',$id)->get('glh')->row();
        $code=($hdr && property_exists($hdr,'code')) ? $hdr->code : '';
        $approvedBy=$this->get_dvh_approved_by($id,$code);
        if($this->has_approval($approvedBy)){
            echo json_encode(array('ok'=>0,'msg'=>'this transaction is approved. unapprove first.'));
            return;
        }
    }

    $dat=array();
    $dat[$fld]=$val;
    if($fld==='void'){
        $voidBy='';
        if(intval($val)===1){
            $voidBy=$this->current_user_display_name();
        }
        $dat['void_by']=($voidBy!=='') ? $voidBy : null;
        if(intval($val)===0){ $dat['void_by']=null; }
    }
    $this->db->where('id',$id)->update('glh',$dat);
    echo json_encode(array('ok'=>1));
}

private function get_dvh_approved_by($glhId,$glhCode='') {
    if(intval($glhId)===0){ return 0; }
    $row=$this->db->select('app,app_by')->where('id',$glhId)->get('glh')->row();
    if($row){
        $appVal=property_exists($row,'app') ? intval($row->app) : 0;
        $appBy=property_exists($row,'app_by') ? $row->app_by : '';
        if($appVal>0){
            if($appBy!==null && trim((string)$appBy)!==''){ return $appBy; }
            return 1;
        }
    }
    return 0;
}

private function get_user_name_by_id($uid){
    $uid=intval($uid);
    if($uid<=0){ return ''; }
    $row=$this->db->select('name')->where('id',$uid)->get('users')->row();
    return $row ? (string)$row->name : '';
}

private function current_user_display_name(){
    $uid=isset($_SESSION['user_id']) ? intval($_SESSION['user_id']) : 0;
    if($uid<=0){ return ''; }
    $name=$this->get_user_name_by_id($uid);
    return $name!=='' ? $name : (string)$uid;
}

private function row_value($row,$keys){
    foreach($keys as $key){
        if(is_array($row) && isset($row[$key]) && trim((string)$row[$key])!==''){
            return (string)$row[$key];
        }
        if(is_object($row) && property_exists($row,$key) && trim((string)$row->$key)!==''){
            return (string)$row->$key;
        }
    }
    return '';
}

private function emp_display_label($row){
    $empNo=$this->row_value($row,array('empno','emp_no','emp_num','emp_number'));
    $fname=$this->row_value($row,array('fname','first_name','firstname'));
    $mname=$this->row_value($row,array('mname','middle_name','middlename'));
    $lname=$this->row_value($row,array('lname','last_name','lastname'));
    $full=trim(preg_replace('/\s+/', ' ', trim($fname.' '.$mname.' '.$lname)));
    $label=$empNo;
    if($full!==''){
        $label=($empNo!=='') ? ($empNo.' - '.$full) : $full;
    }
    if($label===''){
        $idVal=$this->row_value($row,array('id'));
        if($idVal!==''){ $label='employee '.$idVal; }
    }
    return $label;
}

private function parse_subsi_value($raw){
    if($raw===null){ return array('id'=>0,'type'=>'','branch'=>0); }
    $val=trim((string)$raw);
    if($val===''){ return array('id'=>0,'type'=>'','branch'=>0); }
    if(is_numeric($val)){
        $id=intval($val);
        return array('id'=>$id,'type'=>'subsi','branch'=>$id);
    }
    if(preg_match('/^(emp|e)[:\-](\d+)$/i',$val,$m)){
        $id=intval($m[2]);
        return array('id'=>$id,'type'=>'emp','branch'=>-$id);
    }
    if(preg_match('/^(sub|s)[:\-](\d+)$/i',$val,$m)){
        $id=intval($m[2]);
        return array('id'=>$id,'type'=>'subsi','branch'=>$id);
    }
    return array('id'=>0,'type'=>'','branch'=>0);
}

private function is_same_user($uid,$uname,$byVal){
    if($byVal===null){ return false; }
    if(is_numeric($byVal)){ return intval($byVal)===intval($uid); }
    $byStr=trim((string)$byVal);
    if($byStr===''){ return false; }
    if($uname===''){ return false; }
    return strcasecmp($byStr,$uname)===0;
}

private function has_approval($approvedVal){
    if(is_numeric($approvedVal)){ return intval($approvedVal)>0; }
    return is_string($approvedVal) && trim($approvedVal)!=='';
}

private function approved_display_name($approvedVal){
    if(!$this->has_approval($approvedVal)){ return ''; }
    if(is_numeric($approvedVal)){
        $name=$this->get_user_name_by_id(intval($approvedVal));
        return $name!=='' ? $name : (string)$approvedVal;
    }
    return trim((string)$approvedVal);
}

private function branch_display_label($branchData){
    $code='';
    $name='';
    if(is_array($branchData)){
        if(isset($branchData['cd_branch']) && trim((string)$branchData['cd_branch'])!==''){
            $code=trim((string)$branchData['cd_branch']);
        } else if(isset($branchData['code']) && trim((string)$branchData['code'])!==''){
            $code=trim((string)$branchData['code']);
        }
        if(isset($branchData['name'])){
            $name=trim((string)$branchData['name']);
        }
    } else if(is_object($branchData)){
        if(property_exists($branchData,'cd_branch') && trim((string)$branchData->cd_branch)!==''){
            $code=trim((string)$branchData->cd_branch);
        } else if(property_exists($branchData,'code') && trim((string)$branchData->code)!==''){
            $code=trim((string)$branchData->code);
        }
        if(property_exists($branchData,'name')){
            $name=trim((string)$branchData->name);
        }
    }
    if($code!=='' && $name!==''){ return $code.' - '.$name; }
    if($code!==''){ return $code; }
    return $name;
}

private function update_dvh_approval($glhId,$glhCode,$approvedBy,$unapproveBy=null){
    $row=$this->db->select('id')->where('id',$glhId)->get('glh')->row();
    if(!$row){ return false; }
    if($approvedBy!==null && $approvedBy!==''){
        $dat=array('app'=>1,'app_by'=>$approvedBy);
    } else {
        $dat=array('app'=>0,'app_by'=>null);
    }
    $this->db->where('id',$glhId)->update('glh',$dat);
    return true;
}

function Approve() {
    $id=intval($this->input->post('id'));
    $sw=intval($this->input->post('sw'));
    if($id<=0){
        echo json_encode(array('ok'=>0,'msg'=>'invalid transaction'));
        return;
    }
    if($sw!==0){ $sw=1; }

    $hdr=$this->db->where('id',$id)->get('glh')->row();
    if(!$hdr){
        echo json_encode(array('ok'=>0,'msg'=>'transaction not found'));
        return;
    }
    $fin=property_exists($hdr,'fin') ? intval($hdr->fin) : 0;
    $voidVal=property_exists($hdr,'void') ? intval($hdr->void) : 0;
    $code=property_exists($hdr,'code') ? $hdr->code : '';
    $finBy=property_exists($hdr,'fin_by') ? $hdr->fin_by : '';
    $uid=isset($_SESSION['user_id']) ? intval($_SESSION['user_id']) : 0;
    $uname=$this->get_user_name_by_id($uid);
    if($this->is_same_user($uid,$uname,$finBy)){
        echo json_encode(array('ok'=>0,'msg'=>'approval must be done by other user'));
        return;
    }
    if($sw==1){
        if($fin<=0){
            echo json_encode(array('ok'=>0,'msg'=>'transaction must be finalized first'));
            return;
        }
        if($voidVal>0){
            echo json_encode(array('ok'=>0,'msg'=>'cannot approve a voided transaction'));
            return;
        }
        $ok=$this->update_dvh_approval($id,$code,$this->current_user_display_name(),null);
    } else {
        $ok=$this->update_dvh_approval($id,$code,'',null);
    }
    if(!$ok){
        echo json_encode(array('ok'=>0,'msg'=>'approval record not found'));
        return;
    }
    echo json_encode(array('ok'=>1));
}

function Fin() {
    $id=intval($this->input->post('id'));
    $sw=intval($this->input->post('sw'));
    if($id<=0){
        echo json_encode(array('ok'=>0,'msg'=>'invalid transaction'));
        return;
    }
    $hdr=$this->db->where('id',$id)->get('glh')->row();
    if(!$hdr){
        echo json_encode(array('ok'=>0,'msg'=>'transaction not found'));
        return;
    }
    $fin=property_exists($hdr,'fin') ? intval($hdr->fin) : 0;
    $voidVal=property_exists($hdr,'void') ? intval($hdr->void) : 0;
    $code=property_exists($hdr,'code') ? $hdr->code : '';
    $approvedBy=$this->get_dvh_approved_by($id,$code);

    if($sw==0 && $this->has_approval($approvedBy)){
        echo json_encode(array('ok'=>0,'msg'=>'this transaction is approved. unapprove first.'));
        return;
    }
    if($sw==1 && $voidVal>0){
        echo json_encode(array('ok'=>0,'msg'=>'cannot finalize a voided transaction'));
        return;
    }

    $dat=array('fin'=>($sw==1 ? 1 : 0));
    if($sw==1){
        $finBy=$this->current_user_display_name();
        $dat['fin_by']=($finBy!=='') ? $finBy : null;
    } else {
        $dat['fin_by']=null;
    }
    $this->db->where('id',$id)->update('glh',$dat);
    echo json_encode(array('ok'=>1));
}
    
