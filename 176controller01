@media print {
  body { margin: 0; }
  .page { padding: 0.35in; max-width: none; width: 100%; margin: 0; min-height: 10in; page-break-after: always; }
  .page.last { page-break-after: auto; }
  thead { display: table-header-group; }
  tr { page-break-inside: avoid; break-inside: avoid; }
  .total-row, .print-footer { page-break-inside: avoid; break-inside: avoid; }
}
</style>
<script>
function jvPad(n){ return (n < 10) ? ("0" + n) : String(n); }
function jvFormatPrintedOn(d){
  var hours = d.getHours();
  var ampm = (hours >= 12) ? "PM" : "AM";
  var hh = hours % 12;
  if(hh === 0){ hh = 12; }
  return jvPad(d.getMonth()+1) + "/" + jvPad(d.getDate()) + "/" + d.getFullYear() + " " +
         jvPad(hh) + ":" + jvPad(d.getMinutes()) + ":" + jvPad(d.getSeconds()) + " " + ampm;
}
function jvUpdatePrintedOn(){
  var el = document.getElementById("printedOn");
  if(!el){ return; }
  el.textContent = jvFormatPrintedOn(new Date());
}
window.addEventListener("beforeprint", jvUpdatePrintedOn);
window.addEventListener("load", jvUpdatePrintedOn);
</script>
