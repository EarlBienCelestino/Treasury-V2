.signatories { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; text-align: center; }
.sig-line { border-top: 1px solid #000; height: 16px; }
.sig-name { margin-top: 4px; font-weight: 700; font-size: 12px; letter-spacing: 0.3px; }
