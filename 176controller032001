private function next_jv_code() {
    $rs=$this->db
        ->like('code','JV','after')
        ->order_by('code','desc')
        ->limit(1)
        ->get('glh')->result_array();
    $seq=1;
    if(count($rs)>0){
        $last=$rs[0]['code'];
        if(preg_match('/^JV(\d+)$/', $last, $m)){
            $seq=intval($m[1]) + 1;
        } else {
            $digits=preg_replace('/\D+/', '', $last);
            if($digits!==''){ $seq=intval($digits) + 1; }
        }
    }
    return 'JV'.str_pad($seq, 8, '0', STR_PAD_LEFT);
}

