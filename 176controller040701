private function jv_list_display_by_field($row,$statusField,$byField,&$userCache) {
    $statusVal=isset($row[$statusField]) ? intval($row[$statusField]) : 0;
    $byVal=isset($row[$byField]) ? $row[$byField] : '';
    if($statusVal<=0 || !$this->has_approval($byVal)){ return ''; }

    if(is_numeric($byVal)){
        $aid=intval($byVal);
        if(!isset($userCache[$aid])){
            $userCache[$aid]=$this->approved_display_name($byVal);
        }
        return $userCache[$aid];
    }

    return $this->approved_display_name($byVal);
}

private function jv_list_rows($ds='',$de='',$qs='') {
    $ds=is_string($ds) ? trim($ds) : '';
    $de=is_string($de) ? trim($de) : '';
    $qs=is_string($qs) ? trim($qs) : '';
    $columns=$this->jv_list_columns();
    $selectFields=array('id','fin','void','app');

    foreach($columns as $col){
        if(!in_array($col['field'],$selectFields,true)){ $selectFields[]=$col['field']; }
    }

    $query=$this->db->select($selectFields)->where('ty_tran','03');
    if(preg_match('/^\d{4}-\d{2}-\d{2}$/',$ds)){ $query->where('date_>=',$ds); }
    if(preg_match('/^\d{4}-\d{2}-\d{2}$/',$de)){ $query->where('date_<=',$de); }

    $rows=$query
        ->order_by('id','desc')
        ->limit($qs!=='' ? 300 : 50)
        ->get('glh')
        ->result_array();

    $hdrIds=array();
    foreach($rows as $row){
        $rid=isset($row['id']) ? intval($row['id']) : 0;
        if($rid>0){ $hdrIds[]=$rid; }
    }

    $totalsMap=$this->glh_detail_totals_map($hdrIds);
    $userCache=array();
    $out=array();

    foreach($rows as $row){
        $rowId=isset($row['id']) ? intval($row['id']) : 0;
        $cells=array();
        $searchParts=array();

        foreach($columns as $col){
            $fieldName=$col['field'];
            $datafld='';

            if($fieldName==='fin_by'){
                $datafld=$this->jv_list_display_by_field($row,'fin','fin_by',$userCache);
            }
            else if($fieldName==='void_by'){
                $datafld=$this->jv_list_display_by_field($row,'void','void_by',$userCache);
            }
            else if($fieldName==='app_by'){
                $datafld=$this->jv_list_display_by_field($row,'app','app_by',$userCache);
            }
            else {
                $datafld=isset($row[$fieldName]) ? $row[$fieldName] : '';
                if($fieldName==='am_dr' || $fieldName==='am_cr'){
                    if(isset($totalsMap[$rowId])){
                        $datafld=($fieldName==='am_dr') ? $totalsMap[$rowId]['am_dr'] : $totalsMap[$rowId]['am_cr'];
                    }
                    if($datafld===null || $datafld===''){
                        $datafld='';
                    }
                    else {
                        $num=is_numeric($datafld) ? floatval($datafld) : 0;
                        $datafld=number_format($num,2);
                    }
                }
                else if($datafld===null || $datafld===''){
                    $datafld='';
                }
            }

            $cells[$fieldName]=(string)$datafld;
            $searchParts[]=(string)$datafld;
        }

        $rawDate=isset($row['date_']) ? trim((string)$row['date_']) : '';
        if($rawDate!==''){
            $searchParts[]=$rawDate;
            $stamp=strtotime($rawDate);
            if($stamp!==false){
                $searchParts[]=date('m/d/Y',$stamp);
            }
        }

        if($qs!==''){
            $matched=false;
            foreach($searchParts as $part){
                if($part!=='' && stripos($part,$qs)!==false){
                    $matched=true;
                    break;
                }
            }
            if(!$matched){ continue; }
        }

        $out[]=array(
            'id'=>$rowId,
            'cells'=>$cells
        );

        if($qs!=='' && count($out)>=50){ break; }
    }

    return array($columns,$out);
}

