private function jv_sequence_from_value($value) {
    $value=strtoupper(trim((string)$value));
    if($value===''){ return 0; }

    if(preg_match('/^JV(\d+)$/', $value, $m)){
        return intval($m[1]);
    }

    $digits=preg_replace('/\D+/', '', $value);
    if($digits===''){ return 0; }

    return intval($digits);
}

private function jv_max_sequence_in_table($table,$field) {
    if(!$this->db->table_exists($table)){ return 0; }

    $fields=$this->db->list_fields($table);
    if(!in_array($field,$fields,true)){ return 0; }

    $rows=$this->db
        ->select($field)
        ->like($field,'JV','after')
        ->order_by('id','desc')
        ->limit(50)
        ->get($table)
        ->result_array();

    $maxSeq=0;
    foreach($rows as $row){
        $seq=$this->jv_sequence_from_value(isset($row[$field]) ? $row[$field] : '');
        if($seq>$maxSeq){ $maxSeq=$seq; }
    }

    return $maxSeq;
}

private function next_jv_code() {
    $seq=max(
        $this->jv_max_sequence_in_table('glh','code'),
        $this->jv_max_sequence_in_table('glh','doc_code'),
        $this->jv_max_sequence_in_table('collh','jv_no')
    ) + 1;

    return 'JV'.str_pad($seq, 8, '0', STR_PAD_LEFT);
}

