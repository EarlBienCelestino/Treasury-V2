private function glh_detail_totals_map($ids) {
    if(!$this->db->table_exists('gld')){ return array(); }

    $clean=array();
    foreach((array)$ids as $id){
        $id=intval($id);
        if($id>0){ $clean[$id]=$id; }
    }

    if(count($clean)===0){ return array(); }

    $rows=$this->db
        ->select('id, SUM(CASE WHEN amount > 0 THEN amount ELSE 0 END) AS am_dr, SUM(CASE WHEN amount < 0 THEN ABS(amount) ELSE 0 END) AS am_cr', false)
        ->where('sw',1)
        ->where_in('id',array_values($clean))
        ->group_by('id')
        ->get('gld')
        ->result_array();

    $out=array();
    foreach($rows as $row){
        $rid=intval(isset($row['id']) ? $row['id'] : 0);
        if($rid<=0){ continue; }
        $out[$rid]=array(
            'am_dr'=>round(floatval(isset($row['am_dr']) ? $row['am_dr'] : 0),2),
            'am_cr'=>round(floatval(isset($row['am_cr']) ? $row['am_cr'] : 0),2)
        );
    }

    return $out;
}

private function sync_glh_amounts($id) {
    $id=intval($id);
    if($id<=0 || !$this->db->table_exists('glh')){ return array('am_dr'=>0,'am_cr'=>0); }

    $totalsMap=$this->glh_detail_totals_map(array($id));
    $totals=isset($totalsMap[$id]) ? $totalsMap[$id] : array('am_dr'=>0,'am_cr'=>0);

    $fields=$this->db->list_fields('glh');
    $dat=array();
    if(in_array('am_dr',$fields,true)){ $dat['am_dr']=number_format($totals['am_dr'],2,'.',''); }
    if(in_array('am_cr',$fields,true)){ $dat['am_cr']=number_format($totals['am_cr'],2,'.',''); }

    if(count($dat)>0){
        $this->db->where('id',$id)->update('glh',$dat);
    }

    return $totals;
}

