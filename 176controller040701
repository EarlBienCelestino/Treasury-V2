function Approve() {
    $id=intval($this->input->post('id'));
    $sw=intval($this->input->post('sw'));
    if($id<=0){
        echo json_encode(array('ok'=>0,'msg'=>'invalid transaction'));
        return;
    }
    if($sw!==0){ $sw=1; }

    $hdr=$this->db->where('id',$id)->get('glh')->row();
    if(!$hdr){
        echo json_encode(array('ok'=>0,'msg'=>'transaction not found'));
        return;
    }
    $fin=property_exists($hdr,'fin') ? intval($hdr->fin) : 0;
    $voidVal=property_exists($hdr,'void') ? intval($hdr->void) : 0;
    $code=property_exists($hdr,'code') ? $hdr->code : '';
    $finBy=property_exists($hdr,'fin_by') ? $hdr->fin_by : '';
    $uid=isset($_SESSION['user_id']) ? intval($_SESSION['user_id']) : 0;
    $uname=$this->get_user_name_by_id($uid);
    if($this->is_same_user($uid,$uname,$finBy)){
        echo json_encode(array('ok'=>0,'msg'=>'approval must be done by other user'));
        return;
    }
    if($sw==1){
        if($fin<=0){
            echo json_encode(array('ok'=>0,'msg'=>'transaction must be finalized first'));
            return;
        }
        if($voidVal>0){
            echo json_encode(array('ok'=>0,'msg'=>'cannot approve a voided transaction'));
            return;
        }
        $ok=$this->update_dvh_approval($id,$code,$this->current_user_display_name(),null);
    } else {
        $ok=$this->update_dvh_approval($id,$code,'',null);
    }
    if(!$ok){
        echo json_encode(array('ok'=>0,'msg'=>'approval record not found'));
        return;
    }
    echo json_encode(array('ok'=>1));
}

function Fin() {
    $id=intval($this->input->post('id'));
    $sw=intval($this->input->post('sw'));
    if($id<=0){
        echo json_encode(array('ok'=>0,'msg'=>'invalid transaction'));
        return;
    }
    $hdr=$this->db->where('id',$id)->get('glh')->row();
    if(!$hdr){
        echo json_encode(array('ok'=>0,'msg'=>'transaction not found'));
        return;
    }
    $fin=property_exists($hdr,'fin') ? intval($hdr->fin) : 0;
    $voidVal=property_exists($hdr,'void') ? intval($hdr->void) : 0;
    $code=property_exists($hdr,'code') ? $hdr->code : '';
    $approvedBy=$this->get_dvh_approved_by($id,$code);

    if($sw==0 && $this->has_approval($approvedBy)){
        echo json_encode(array('ok'=>0,'msg'=>'this transaction is approved. unapprove first.'));
        return;
    }
    if($sw==1 && $voidVal>0){
        echo json_encode(array('ok'=>0,'msg'=>'cannot finalize a voided transaction'));
        return;
    }
    if($sw==1){
        $balanceState=$this->detail_balance_state($id);
