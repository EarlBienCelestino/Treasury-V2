    $subsiValue='0';
    $subsiText='';

    if($id2<0){
        $subsiId=abs($id2);
        $subsiType='emp';
        $subsiValue='emp:'.$subsiId;
        $empTable='hr_mf_emp';
        $empTableExists=method_exists($this->db,'table_exists') ? $this->db->table_exists($empTable) : true;
        if($empTableExists && $subsiId>0){
            $empRow=$this->db->where('id',$subsiId)->get($empTable)->row();
            if($empRow){ $subsiText=$this->emp_display_label($empRow); }
