function setFinalizedState(isFinalized){
    var $fields = $("#particulars, #date_, #no_ref, #dt_refdoc, #no_refdoc, #void");
    $fields.prop("disabled", isFinalized);

    $("#sub-branch, #sub-coa, #subsi-code, #subsi-remarks, #subsi-amount").prop("disabled", isFinalized);
    $("#details-btns input, #subsi-btns input, #jv-delete-selected, #jv-delete-cancel").prop("disabled", isFinalized);
    $("#subsi-section :input").prop("disabled", isFinalized);

    var $finBtn = $("#Finx");
    if($finBtn.length){
        if(isApproved){
            $finBtn.hide();
        } else {
            $finBtn.show();
            if(isFinalized){
                $finBtn.val("Unfinalize").attr("onclick","Fin(0)");
            } else {
                $finBtn.val("Finalize").attr("onclick","Fin(1)");
            }
        }
    }

    var $appBtn = $("#app");
    var $unappBtn = $("#unapp");
    if(!canApprove){
        if($appBtn.length){ $appBtn.hide(); }
        if($unappBtn.length){ $unappBtn.hide(); }
        return;
    }
    if(isFinalized){
        if(isApproved){
            if($appBtn.length){ $appBtn.hide(); }
            if($unappBtn.length){ $unappBtn.prop("disabled", false).show(); }
        } else {
            if($appBtn.length){ $appBtn.prop("disabled", false).show(); }
            if($unappBtn.length){ $unappBtn.hide(); }
        }
    } else {
        if($appBtn.length){ $appBtn.hide(); }
        if($unappBtn.length){ $unappBtn.hide(); }
    }
}

