function jvPad(n){ return (n < 10) ? ("0" + n) : String(n); }
function jvFormatPrintedOn(d){
  var hours = d.getHours();
  var ampm = (hours >= 12) ? "PM" : "AM";
  var hh = hours % 12;
  if(hh === 0){ hh = 12; }
  return jvPad(d.getMonth()+1) + "/" + jvPad(d.getDate()) + "/" + d.getFullYear() + " " +
         jvPad(hh) + ":" + jvPad(d.getMinutes()) + ":" + jvPad(d.getSeconds()) + " " + ampm;
}
function jvUpdatePrintedOn(){
  var el = document.getElementById("printedOn");
  if(!el){ return; }
  el.textContent = jvFormatPrintedOn(new Date());
}
function jvCreatePage(isLast){
  var page = document.createElement("div");
  page.className = "page" + (isLast ? " last" : "");
  page.innerHTML = jvHeaderHtml + jvTableShell + (isLast ? jvFooterHtml : "");
  return page;
}
function jvRenderPage(rows, isLast){
  var page = jvCreatePage(isLast);
  var body = page.querySelector("tbody");
  if(rows.length > 0){
    body.insertAdjacentHTML("beforeend", rows.join(""));
  }
  return page;
}
function jvPageFits(host, rows, isLast){
  host.innerHTML = "";
  var page = jvRenderPage(rows, isLast);
  host.appendChild(page);
  return page.scrollHeight <= (page.clientHeight + 1);
}
function jvSplitLastPage(host, pages){
  var carry = pages.pop().slice();
  var newLast = [];

  while(carry.length > 0){
    var candidate = carry[carry.length - 1];
    newLast.unshift(candidate);
    if(jvPageFits(host, newLast, true)){
      carry.pop();
    } else {
      newLast.shift();
      break;
    }
  }

  if(newLast.length === 0 && carry.length > 0){
    newLast.unshift(carry.pop());
  }

  if(carry.length > 0){
    pages.push(carry);
  }
  pages.push(newLast);
}
function jvBuildPages(){
  var pagesHost = document.getElementById("jv-pages");
  var measureHost = document.getElementById("jv-measure");
  if(!pagesHost || !measureHost){ return; }

  var pages = [[]];
  for(var i = 0; i < jvRowHtmls.length; i++){
    var current = pages[pages.length - 1];
    current.push(jvRowHtmls[i]);
    if(!jvPageFits(measureHost, current, false)){
      current.pop();
      if(current.length === 0){
        current.push(jvRowHtmls[i]);
      } else {
        pages.push([jvRowHtmls[i]]);
      }
    }
  }

  if(pages.length === 0){
    pages = [[]];
  }

  if(!jvPageFits(measureHost, pages[pages.length - 1], true)){
    jvSplitLastPage(measureHost, pages);
  }

