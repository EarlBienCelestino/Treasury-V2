    if(property_exists($hdr,'fin') && intval($hdr->fin)>0){
        echo json_encode(array('ok'=>0,'msg'=>'transaction is finalized'));
        return;
    }
    if(property_exists($hdr,'void') && intval($hdr->void)>0){
        echo json_encode(array('ok'=>0,'msg'=>'transaction is void'));
        return;
    }

    $rows=json_decode($rowsJson,true);
    if(!is_array($rows) || count($rows)==0){
        echo json_encode(array('ok'=>0,'msg'=>'no entries to save'));
        return;
    }

    $sum=0;
    $insertRows=array();
    foreach($rows as $row){
        $branch=isset($row['branch_id']) ? intval($row['branch_id']) : 0;
        $coa=isset($row['coa_id']) ? intval($row['coa_id']) : 0;
        $remarks=isset($row['remarks']) ? strtoupper(trim((string)$row['remarks'])) : '';
        if($remarks==='' && isset($row['particulars'])){
            $remarks=strtoupper(trim((string)$row['particulars']));
        }
        $subsiText=isset($row['subsi_text']) ? trim((string)$row['subsi_text']) : '';
        $subsiRaw=isset($row['subsi_value']) ? trim((string)$row['subsi_value']) : '';
        if($subsiRaw==='' && isset($row['subsi_id']) && intval($row['subsi_id'])>0){
            $tmpType=isset($row['subsi_type']) ? strtolower(trim((string)$row['subsi_type'])) : 'sub';
            $subsiRaw=(($tmpType==='emp' || $tmpType==='e') ? 'emp:' : 'sub:').intval($row['subsi_id']);
        }
        $id2=$this->detail_id2_from_subsi_value($subsiRaw);
        $part=$this->build_detail_particulars($subsiText,$remarks);
        $amt=isset($row['amount']) ? floatval($row['amount']) : 0;

        if($branch<=0 || $coa<=0 || $remarks==='' || $amt==0 || $id2===0){
            continue;
        }
        $sum+=$amt;
        $insertRows[]=array(
            'sw'=>1,
            'id'=>$id,
            'branch'=>$branch,
            'coa'=>$coa,
            'remarks'=>$remarks,
            'id2'=>$id2,
            'particulars'=>$part,
            'amount'=>$amt
        );
    }

    if(count($insertRows)==0){
        echo json_encode(array('ok'=>0,'msg'=>'no valid entries to save'));
        return;
    }
    if(abs($sum) > 0.0001){
        echo json_encode(array('ok'=>0,'msg'=>'balance must be 0'));
        return;
    }

    $this->db->insert_batch('gld',$insertRows);
    $totals=$this->sync_glh_amounts($id);
    $balanceState=$this->detail_balance_state($id);
    echo json_encode(array(
        'ok'=>1,
        'count'=>count($insertRows),
        'am_dr'=>$totals['am_dr'],
        'am_cr'=>$totals['am_cr'],
        'balance'=>$balanceState['balance']
    ));
}

