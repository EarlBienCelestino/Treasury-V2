        $subsiType='subsi';
        $subsiValue='sub:'.$subsiId;
        $subsiRow=$this->db->where('id',$subsiId)->get('subsi')->row();
        if($subsiRow){ $subsiText=$this->subsi_display_label($subsiRow); }
    }

    if($remarks!=='' && $particulars!==''){
        $partUpper=strtoupper($particulars);
        $remarksLen=strlen($remarks);
        if($remarksLen>0 && strlen($partUpper)>=$remarksLen && substr($partUpper,-$remarksLen)===$remarks){
            $prefix=trim(substr($particulars,0,strlen($particulars)-$remarksLen));
            if($prefix!==''){ $subsiText=$prefix; }
        }
    }

    if($remarks==='' && $subsiText!=='' && stripos($particulars,$subsiText)===0){
        $remarks=trim(substr($particulars,strlen($subsiText)));
    }
    if($remarks===''){ $remarks=$particulars; }

    return array(
        'id'=>$subsiId,
        'type'=>$subsiType,
        'value'=>$subsiValue,
        'text'=>$subsiText,
        'remarks'=>$remarks
    );
}

