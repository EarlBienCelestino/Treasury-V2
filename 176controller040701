            echo json_encode(array(
                'ok'=>0,
                'msg'=>'balance must be 0 before finalizing',
                'am_dr'=>$balanceState['am_dr'],
                'am_cr'=>$balanceState['am_cr'],
                'balance'=>$balanceState['balance']
            ));
            return;
        }
    }

    $dat=array('fin'=>($sw==1 ? 1 : 0));
    if($sw==1){
        $finBy=$this->current_user_display_name();
        $dat['fin_by']=($finBy!=='') ? $finBy : null;
    } else {
        $dat['fin_by']=null;
    }
    $this->db->where('id',$id)->update('glh',$dat);
    $balanceState=$this->detail_balance_state($id);
    echo json_encode(array(
        'ok'=>1,
        'am_dr'=>$balanceState['am_dr'],
        'am_cr'=>$balanceState['am_cr'],
        'balance'=>$balanceState['balance']
    ));
}
    
