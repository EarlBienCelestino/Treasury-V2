function jvSyncHeaderId(){
    var idVal = 0;
    var $id = $("#id");
    if($id.length){
        idVal = parseInt($id.last().val(),10) || 0;
    }
    if($("#subs-hdr-id").length){
        idVal = parseInt($("#subs-hsdr-id").val(),10) || idVal;
    }
    if(jvCurrentHdrId !== idVal){
        jvTempRows = [];
        jvDeleteMode = false;
