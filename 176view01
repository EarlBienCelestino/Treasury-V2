<script> 
    
    
function add() { 
    showAddForm();
}  

var qsTimer = null;

function qsDebounced() {
    clearTimeout(qsTimer);
    qsTimer = setTimeout(function() {
        var val = $("#qs").val().trim();
        if(val === "") { 
            list(); 
        } else { 
            qs(); 
        }
    }, 300);
}

function setupStartDateInput() {
    var $ds = $("#ds");
    if($ds.val() === "") { $ds.val("select date"); }
    if($ds.val() === "select date") { $ds.attr("type","text"); }

    $ds.on("focus", function() {
        if(this.value === "select date") { this.value = ""; }
        this.type = "date";
    });

    $ds.on("blur", function() {
        if(!this.value) {
            this.type = "text";
            this.value = "select date";
        }
    });
}

function getStartDateValue() {
    var dsVal = $("#ds").val();
    if(dsVal === "select date") { return ""; }
    return dsVal;
}

function showAddForm() {
    $("#form_entry").empty();
    $("#forms").show();
    $("#add_form").show();
    resetAddForm();
}

function resetAddForm() {
    $("#add_particulars").val("");
    $("#add_am_dr").val("");
    $("#add_am_cr").val("");
    $("#add_no_ref").val("");
    $("#add_dt_refdoc").val("");
    $("#add_no_refdoc").val("");
}

function closeAddForm() {
    $("#add_form").hide();
    $("#forms").hide();
    resetAddForm();
}

function finalizeAdd() {
    var particulars = $("#add_particulars").val().trim();
    var amDr = $("#add_am_dr").val().trim();
    var amCr = $("#add_am_cr").val().trim();
    var noRef = $("#add_no_ref").val().trim();
    var dtRef = $("#add_dt_refdoc").val().trim();
    var noRefDoc = $("#add_no_refdoc").val().trim();

    if(particulars === "" || amDr === "" || amCr === "" || noRef === "" || dtRef === "" || noRefDoc === "" 
        || isNaN(parseFloat(amDr)) || isNaN(parseFloat(amCr))){
        alert("complete all the fields first");
        return;
    }
    $.ajax({
        url:"<?=base_url('176/dashboard/add_save')?>",
        dataType:"json",
        method:"POST",
        data:{
            particulars: particulars,
            am_dr: amDr,
            am_cr: amCr,
            no_ref: noRef,
            dt_refdoc: dtRef,
            no_refdoc: noRefDoc
        },
        success:function(data){
            if(!data || data.ok === 0){
                alert((data && data.msg) ? data.msg : "complete all the fields first");
                return;
            }
            alert("record saved...");
            closeAddForm();
            list();
        }
    });
}

function  View() {
    list() ;
}
    
function  qs() {
    $.ajax({url:"<?=base_url('176/dashboard/list2')?>",method:"POST",data:{
        qs:$("#qs").val()  
        
    },success:function(data) {  
         $("#form_entry").empty(); 
        $("#list").html(data); 
        $("#xsearch").show();   
         } 
        }); 
} 
    
function  list() {
    $.ajax({url:"<?=base_url('176/dashboard/list')?>",method:"POST",data:{
        qs:$("#qs").val() 
        ,ds:getStartDateValue() 
        ,de:$("#de").val() 
        
    },success:function(data) {  
         $("#form_entry").empty(); 
        $("#list").html(data); 
        $("#xsearch").show();   
         } 
        }); 
} 

