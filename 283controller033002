function compute_amount(disb_val){
    var disb = parseFloat(disb_val);
    if(isNaN(disb)){
        disb = parseFloat($("#total_disb").val());
    }
    if(isNaN(disb)){ disb = 0; }

    var total = parseFloat($("#breakdown_total").val());
    if(isNaN(total)){ total = 0; }

    var diff = Math.abs(disb - total);
    $("#amount").val(diff.toFixed(2));
    fsave("amount");

    var type_val = (disb > total) ? 1 : 2;
    if(disb === total){
        type_val = 1;
    }

    $("#type_").val(type_val);
    fsave("type_");
}
