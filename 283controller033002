function upload($id) {
    if (empty($_FILES['image_file23']['tmp_name'])) {
        echo json_encode(['error' => 'No file received.']);
        return;
    }

    $allowed_types = ['image/jpeg', 'image/png', 'image/gif', 'application/pdf'];
    $mime = mime_content_type($_FILES['image_file23']['tmp_name']);

    if (!in_array($mime, $allowed_types)) {
        echo json_encode(['error' => 'Invalid file type. Allowed: jpg, png, gif, pdf.']);
        return;
    }

    if ($_FILES['image_file23']['size'] > 5 * 1024 * 1024) {
        echo json_encode(['error' => 'File exceeds 5MB limit.']);
        return;
    }

    $b64      = base64_encode(file_get_contents($_FILES['image_file23']['tmp_name']));
    $orig_name = basename($_FILES['image_file23']['name']);

    $this->db->where('id', $id)->update('liqh', [
        'photo'      => $orig_name
    ]);

    if ($mime === 'application/pdf') {
        $img_tag = '<a href="data:application/pdf;base64,'.$b64.'" target="_blank" download="'.htmlspecialchars($orig_name,ENT_QUOTES).'">
                    <span style="font-size:32px;">&#128196;</span><br><small>'.htmlspecialchars($orig_name,ENT_QUOTES).'</small></a>';
    } 
    else {
        $img_tag = '<a href="data:'.$mime.';base64,'.$b64.'" target="_blank">
                    <img src="data:'.$mime.';base64,'.$b64.'" width="100" height="75" style="object-fit:cover;"></a>';
    }

    echo json_encode(['img' => $img_tag, 'filename' => $orig_name]);
}

