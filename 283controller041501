function get_amt() {
    header('Content-Type: application/json');

    $id = intval($this->input->post('id'));
    $dat = array(
    'amt'           => 0,
    'location'      => 0,
    'location_name' => '',
    'payee'         => '',
    'trncode'       => ''
);

    if ($id <= 0) {
        echo json_encode($dat);
        exit;
    }

    $dv = $this->db
    ->select('id, location, payee, cash, trncode')
    ->where('id', $id)
    ->get('dvh')
    ->row();

if ($dv) {
    $dat['amt']     = floatval($dv->cash);
    $dat['location']= intval($dv->location);
    $dat['payee']   = trim((string)$dv->payee);
    $dat['trncode'] = trim((string)$dv->trncode);

        if ($dat['location'] > 0) {
            $loc_row = $this->db
                ->select('id, name')
                ->where('id', $dat['location'])
                ->get('location')
                ->row();

            if ($loc_row) {
                $dat['location_name'] = $loc_row->name;
            }
        }
    }

    echo json_encode($dat);
    exit;
}
    
