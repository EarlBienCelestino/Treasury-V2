    <script>
    (function(){
        var finalized = <?=json_encode($fin)?>;

        function initDepositCheckSelectors(){
            if($("#deposit_chk_bank").length && !$("#deposit_chk_bank").hasClass("select2-hidden-accessible")){
                $("#deposit_chk_bank").select2({
                    ajax: {
                        url: "<?=base_url("423/dashboard/mf/deposit_check_bank")?>",
                        type: "post",
                        dataType: "json",
                        delay: 250,
                        data: function(params){ return { searchTerm: params.term }; },
                        processResults: function(response){ return { results: response }; },
                        cache: true
                    }
                });
            }

            if($("#deposit_chk_customer").length && !$("#deposit_chk_customer").hasClass("select2-hidden-accessible")){
                $("#deposit_chk_customer").select2({
                    ajax: {
                        url: "<?=base_url("423/dashboard/mf/deposit_customer")?>",
                        type: "post",
                        dataType: "json",
                        delay: 250,
                        data: function(params){ return { searchTerm: params.term }; },
                        processResults: function(response){ return { results: response }; },
                        cache: true
                    }
                });
            }
        }

        function setDepositSelectValue(selector, value, text){
            var $select=$(selector);

            if(!value){
                $select.val(null).trigger("change");
                return;
            }

            $select.find("option").remove();
            var option = new Option(text, value, true, true);
            $select.append(option).trigger("change");
        }

        function setDepositCheckType(value){
            $(".deposit-type-check").prop("checked", false);
            if(value){
                $("#deposit_type_" + value).prop("checked", true);
            }
        }

        function getDepositCheckType(){
            return $(".deposit-type-check:checked").first().val() || "";
        }

        function currentDepositCheckState(){
            return {
                seq: $("#deposit_check_seq").val() || "0",
                id: $("#deposit_check_parent_id").val() || "0",
                bank: $("#deposit_chk_bank").val() || "",
                chk_no: $.trim($("#deposit_chk_no").val() || ""),
                chk_dt: $("#deposit_chk_dt").val() || "",
                acct_no: $.trim($("#deposit_acct_no").val() || ""),
                branch: $.trim($("#deposit_chk_branch").val() || ""),
                type_: getDepositCheckType(),
                customer: $("#deposit_chk_customer").val() || "",
                amount: $("#deposit_chk_amount").val() || "0.00"
            };
        }

        window.clearDepositCheckForm = function(forceClear){
            var state = currentDepositCheckState();
            var hasValue = state.seq !== "0" || state.bank !== "" || state.chk_no !== "" || state.chk_dt !== "" || state.acct_no !== "" || state.branch !== "" || state.type_ !== "" || state.customer !== "" || parseFloat(state.amount || 0) > 0;

            if(!forceClear && hasValue && !confirm("Clear the current check entry?")){
                return;
            }

            $("#deposit_check_seq").val("0");
            $("#deposit_chk_no").val("");
            $("#deposit_chk_dt").val("");
            $("#deposit_acct_no").val("");
            $("#deposit_chk_branch").val("");
            $("#deposit_chk_amount").val("0.00");
            setDepositCheckType("");

            if($("#deposit_chk_bank").hasClass("select2-hidden-accessible")){
                $("#deposit_chk_bank").val(null).trigger("change");
            }

            if($("#deposit_chk_customer").hasClass("select2-hidden-accessible")){
                $("#deposit_chk_customer").val(null).trigger("change");
            }
        };

        window.fillDepositCheckForm = function(record){
            if(!record){ return; }

            $("#deposit_check_seq").val(record.seq || 0);
            $("#deposit_chk_no").val(record.chk_no || "");
            $("#deposit_chk_dt").val(record.chk_dt || "");
            $("#deposit_acct_no").val(record.acct_no || "");
            $("#deposit_chk_branch").val(record.branch || "");
            $("#deposit_chk_amount").val(record.amount || "0.00");
            setDepositCheckType(record.type_ || "");
            setDepositSelectValue("#deposit_chk_bank", record.chk_bank_id || "", record.bank_name || "");
            setDepositSelectValue("#deposit_chk_customer", record.customer_value || "", record.customer_display || "");
        };

        function validateDepositCheck(){
            var state = currentDepositCheckState();
            var errors = [];

            if(state.bank === ""){ errors.push("Please select a bank."); }
            if(state.chk_no === ""){ errors.push("Please enter the check no."); }
            if(state.chk_dt === ""){ errors.push("Please enter the check date."); }
            if(state.acct_no === ""){ errors.push("Please enter the account no."); }
            if(state.branch === ""){ errors.push("Please enter the branch."); }
            if(state.type_ === ""){ errors.push("Please choose the check type."); }
            if(state.customer === ""){ errors.push("Please select the customer."); }

            var amount = parseFloat(state.amount || 0);
            if(!(amount > 0)){ errors.push("Amount must be greater than zero."); }

            return errors;
        }

        window.saveDepositCheck = function(){
            if(finalized > 0){
                alert("This deposit is finalized.");
                return;
            }

            var errors = validateDepositCheck();
            if(errors.length > 0){
                alert(errors.join("\n"));
                return;
            }

            if(!confirm("Are you sure to save this check record?")){
                return;
            }

            $.ajax({
                url: "<?=base_url("423/dashboard/save_deposit_check")?>",
                method: "POST",
                data: { datas: currentDepositCheckState() },
                success: function(raw){
                    var res = {};

                    try { res = JSON.parse(raw); }
                    catch(err) { res = { success: false, message: "Unable to save the check record." }; }

                    if(!res.success){
                        if(res.message){ alert(res.message); }
                        return;
                    }

                    if(typeof updateDepositHeaderTotals === "function"){
                        updateDepositHeaderTotals(res.check, res.total);
                    }

                    if(typeof loadDepositChecks === "function"){
                        loadDepositChecks(1);
                    }
                }
            });
        };

        window.deleteDepositCheck = function(){
            if(finalized > 0){
                alert("This deposit is finalized.");
                return;
            }

            var seq = $("#deposit_check_seq").val() || "0";
            if(parseInt(seq, 10) <= 0){
                alert("Please select a check record to delete.");
                return;
            }

            if(!confirm("Are you sure to delete this check record?")){
                return;
            }

            $.ajax({
                url: "<?=base_url("423/dashboard/delete_deposit_check")?>",
                method: "POST",
                data: {
                    seq: seq,
                    id: $("#deposit_check_parent_id").val() || "0"
                },
                success: function(raw){
                    var res = {};

                    try { res = JSON.parse(raw); }
                    catch(err) { res = { success: false, message: "Unable to delete the check record." }; }

                    if(!res.success){
                        if(res.message){ alert(res.message); }
                        return;
                    }

                    if(typeof updateDepositHeaderTotals === "function"){
                        updateDepositHeaderTotals(res.check, res.total);
                    }

                    if(typeof loadDepositChecks === "function"){
                        loadDepositChecks(1);
                    }
                }
            });
        };

        $("#deposit_chk_bank")
            .off(".depositCheck")
            .on("select2:select.depositCheck", function(){
                if(finalized > 0){ return; }

                $.ajax({
                    url: "<?=base_url("423/dashboard/deposit_bank_branch")?>",
                    method: "POST",
                    data: { bank_id: $("#deposit_chk_bank").val() || "" },
                    success: function(raw){
                        var res = {};
                        try { res = JSON.parse(raw); }
                        catch(err) { res = {}; }

                        $("#deposit_chk_branch").val(res.branch || "");
                    }
                });
            });

        $(".deposit-type-check")
            .off(".depositCheck")
            .on("change.depositCheck", function(){
                if($(this).is(":checked")){
                    $(".deposit-type-check").not(this).prop("checked", false);
                }
            });

        initDepositCheckSelectors();

        $("#deposit_checks_table").DataTable({
            scrollX: true,
            order: [[0, "desc"]]
        });

        $("#deposit_checks_table tbody")
            .off("click", "tr")
            .on("click", "tr", function(){
                var payload = $(this).attr("data-record") || "{}";
                try { payload = JSON.parse(payload); }
                catch(err) { payload = {}; }
                fillDepositCheckForm(payload);
            });
    })();
    </script>
    <?php
    return ob_get_clean();
}

