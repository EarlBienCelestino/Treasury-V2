    (function(){
        var depositId = <?=json_encode((int)$id)?>;
        var finalized = <?=json_encode($fin)?>;

        function bindDepositHeader(){
            if($("#deposit_account").length && !$("#deposit_account").hasClass("select2-hidden-accessible")){
                $("#deposit_account").select2({
                    ajax: {
                        url: "<?=base_url("423/dashboard/mf/deposit_account")?>",
                        type: "post",
                        dataType: "json",
                        delay: 250,
                        data: function(params){ return { searchTerm: params.term }; },
                        processResults: function(response){ return { results: response }; },
                        cache: true
                    }
                });
            }

            if(finalized > 0){ return; }

            $("#deposit_date, #deposit_ref_no, #deposit_cash")
                .off(".depositHeader")
                .on("change.depositHeader", function(){
                    saveDepositHeader();
                });

            $("#deposit_remarks")
                .off(".depositHeader")
                .on("change.depositHeader blur.depositHeader", function(){
                    saveDepositHeader();
                });

            $("#deposit_account")
                .off(".depositHeader")
                .on("select2:select.depositHeader", function(){
                    saveDepositHeader();
                });
        }

        window.updateDepositHeaderTotals = function(checkValue, totalValue){
            if(checkValue!==undefined){
                $("#deposit_check").val((parseFloat(checkValue || 0) || 0).toFixed(2));
            }
            if(totalValue!==undefined){
                $("#deposit_total").val((parseFloat(totalValue || 0) || 0).toFixed(2));
            }
        };

        window.saveDepositHeader = function(){
            if(finalized > 0){ return; }

            var datas = {
                id: depositId,
                date_: $("#deposit_date").val() || "",
                code: $("#deposit_code").val() || "",
                ref_no: $("#deposit_ref_no").val() || "",
                account: $("#deposit_account").val() || "",
                remarks: $("#deposit_remarks").val() || "",
                cash: $("#deposit_cash").val() || "0.00"
            };

            $.ajax({
                url: "<?=base_url("423/dashboard/save_deposit_header")?>",
                method: "POST",
                data: { datas: datas },
                success: function(raw){
                    var res = {};

                    try { res = JSON.parse(raw); }
                    catch(err) { res = { success: false, message: "Unable to save deposit header." }; }

                    if(!res.success){
                        if(res.message){ alert(res.message); }
                        return;
                    }

                    $("#deposit_cash").val(res.cash || $("#deposit_cash").val());
                    updateDepositHeaderTotals(res.check, res.total);
                }
            });
        };

        window.loadDepositChecks = function(sw){
            $.ajax({
                url: "<?=base_url("423/dashboard/info")?>",
                method: "POST",
                data: { datas: [depositId, sw] },
                success: function(data){
                    $("#d_list").html(data);
                }
            });
        };

        window.toggleDepositFinal = function(sw){
            var msg = (parseInt(sw, 10) === 1) ? "Finalize" : "Unfinalize";
            if(!confirm(msg + " this transaction?")){ return; }

            $.ajax({
                url: "<?=base_url("423/dashboard/Fin")?>",
                method: "POST",
                data: { id: depositId, sw: sw, module: "deposit" },
                success: function(){
                    location.reload();
                }
            });
        };

        bindDepositHeader();
        loadDepositChecks(1);
    })();
    </script>
    <?php
    return ob_get_clean();
}

