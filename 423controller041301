private function dashboard423_create_check_module_header($sw,$date_value='') {
    $config=$this->dashboard423_check_module_config($sw);
    if(!$config){
        return array('success'=>false,'message'=>'Module configuration was not found.');
    }

    $table=$config['header'];
    if(!$this->db->table_exists($table)){
        return array('success'=>false,'message'=>'Header table '.$table.' was not found.');
    }

    $fields=$this->db->list_fields($table);
    $data=array();

    foreach($fields as $field){
        if($field!=='id'){
            $data[$field]='';
        }
    }

    $date_value=trim((string)$date_value);
    if($date_value===''){
        $date_value=date('Y-m-d');
    }

    if(array_key_exists('date_',$data)){ $data['date_']=$date_value; }
    if(array_key_exists('cut_off',$data) && intval($sw)===6){ $data['cut_off']=$date_value; }
    if(array_key_exists('code',$data)){ $data['code']=$this->dashboard423_check_module_next_code($sw); }
    if(array_key_exists('ref_no',$data)){ $data['ref_no']=$this->dashboard423_check_module_next_ref_no($sw); }
    if(array_key_exists('salesman',$data) && in_array((int)$sw,array(4,5),true)){ $data['salesman']='OFFICE'; }
    if(array_key_exists('cash',$data)){ $data['cash']='0.00'; }
    if(array_key_exists('check',$data)){ $data['check']='0.00'; }
    if(array_key_exists('total',$data)){ $data['total']='0.00'; }
    if(array_key_exists('collection',$data)){ $data['collection']='FALSE'; }
    if(array_key_exists('replaced',$data)){ $data['replaced']='FALSE'; }
    if(array_key_exists('others',$data)){ $data['others']='FALSE'; }
    if(array_key_exists('userid',$data)){ $data['userid']=$this->session->userdata('user_id'); }
    if(array_key_exists('fin',$data)){ $data['fin']=0; }

    $this->db->insert($table,$data);

    if($this->db->affected_rows()<=0){
        return array('success'=>false,'message'=>'Unable to create a new '.$config['title'].' entry.');
    }

    return array(
        'success'=>true,
        'id'=>$this->db->insert_id(),
        'code'=>isset($data['code']) ? $data['code'] : '',
        'ref_no'=>isset($data['ref_no']) ? $data['ref_no'] : ''
    );
}

