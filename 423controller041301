function print_view($sw=0,$id=0) {
    $sw=intval($sw);
    $id=intval($id);

    if($id<=0){
        echo '<div style="padding:24px;font-family:Arial,sans-serif;">Invalid print request.</div>';
        return;
    }

    $header=array();
    $left_meta=array();
    $right_meta=array();
    $wide_page=in_array($sw,array(2,4,6),true);
    $page_width=$wide_page ? '297mm' : '210mm';
    $page_min_height=$wide_page ? '210mm' : '297mm';
    $page_size=$wide_page ? 'A4 landscape' : 'A4 portrait';

    if($sw===0){
        $header=$this->dashboard423_pr_header($id);
        if(!$header){
            echo '<div style="padding:24px;font-family:Arial,sans-serif;">Provisional receipt record not found.</div>';
            return;
        }

        $left_meta=array(
            array('label'=>'CUSTOMER / EMP.', 'value'=>$this->dashboard423_payee_display(isset($header['customer']) ? $header['customer'] : '')),
            array('label'=>'SALESMAN', 'value'=>$this->dashboard423_salesman_display(isset($header['salesman']) ? $header['salesman'] : '')),
            array('label'=>'REMARKS', 'value'=>trim((string)(isset($header['remarks']) ? $header['remarks'] : '')))
        );
    }
    else if($sw===1){
        $header=$this->dashboard423_deposit_header($id);
        if(!$header){
            echo '<div style="padding:24px;font-family:Arial,sans-serif;">Deposit slip record not found.</div>';
            return;
        }

        $left_meta=array(
            array('label'=>'BANK', 'value'=>$this->collh_account_display(isset($header['account']) ? $header['account'] : '')),
            array('label'=>'REMARKS', 'value'=>trim((string)(isset($header['remarks']) ? $header['remarks'] : '')))
        );
    }
    else if($sw===2){
        $header=$this->dashboard423_outcheck_header($id);
        if(!$header){
            echo '<div style="padding:24px;font-family:Arial,sans-serif;">Out-check record not found.</div>';
            return;
        }

        $left_meta=array(
            array('label'=>'PARTY', 'value'=>$this->dashboard423_party_display(isset($header['cd_party']) ? $header['cd_party'] : '')),
            array('label'=>'REMARKS', 'value'=>trim((string)(isset($header['remarks']) ? $header['remarks'] : '')))
        );
    }
    else if(in_array($sw,array(3,4,5,6),true)){
        $config=$this->dashboard423_check_module_config($sw);
        if(!$config){
            echo '<div style="padding:24px;font-family:Arial,sans-serif;">Module configuration not found.</div>';
            return;
        }

        $header=$this->db->where('id',$id)->get($config['header'])->row_array();
        if(!$header){
            echo '<div style="padding:24px;font-family:Arial,sans-serif;">Transaction record not found.</div>';
            return;
        }

        if($sw===3){
            $left_meta=array(
                array('label'=>'PARTY', 'value'=>$this->dashboard423_party_display(isset($header['cd_party']) ? $header['cd_party'] : '')),
                array('label'=>'REMARKS', 'value'=>trim((string)(isset($header['remarks']) ? $header['remarks'] : '')))
            );
        }
        else if($sw===4){
            $left_meta=array(
                array('label'=>'CUSTOMER', 'value'=>$this->dashboard423_payee_display(isset($header['customer']) ? $header['customer'] : '')),
                array('label'=>'SALESMAN', 'value'=>$this->dashboard423_salesman_display(isset($header['salesman']) ? $header['salesman'] : '')),
                array('label'=>'REMARKS', 'value'=>trim((string)(isset($header['remarks']) ? $header['remarks'] : '')))
            );
        }
        else if($sw===5){
            $left_meta=array(
                array('label'=>'CUSTOMER', 'value'=>$this->dashboard423_payee_display(isset($header['customer']) ? $header['customer'] : '')),
                array('label'=>'SALESMAN', 'value'=>$this->dashboard423_salesman_display(isset($header['salesman']) ? $header['salesman'] : '')),
                array('label'=>'REMARKS', 'value'=>trim((string)(isset($header['remarks']) ? $header['remarks'] : '')))
            );
        }
        else if($sw===6){
            $left_meta=array(
                array('label'=>'CUT-OFF DATE', 'value'=>$this->dashboard423_print_detail_date(isset($header['cut_off']) ? $header['cut_off'] : '')),
                array('label'=>'REMARKS', 'value'=>trim((string)(isset($header['remarks']) ? $header['remarks'] : '')))
            );
        }
    }
    else {
        echo '<div style="padding:24px;font-family:Arial,sans-serif;">Unsupported print module.</div>';
        return;
    }

    $detail_rows=$this->dashboard423_print_detail_rows($sw,$id);
    $columns=$this->dashboard423_print_detail_columns($sw,$detail_rows);
    $title=$this->dashboard423_print_doc_title($sw);
    $code_label=$this->dashboard423_print_code_label($sw);
    $date_value=isset($header['date_']) ? $header['date_'] : '';
    $code_value=isset($header['code']) ? trim((string)$header['code']) : '';
    $ref_value=isset($header['ref_no']) ? trim((string)$header['ref_no']) : '';
    $total_value=$this->dashboard423_deposit_format_amount(isset($header['total']) ? $header['total'] : 0);

    if($total_value==='0.00' && count($detail_rows)>0){
        $sum=0;
        foreach($detail_rows as $detail_row){
            $amount=$this->dashboard423_print_value_from_candidates($detail_row,array('amount','total','check','cash'));
            $sum+=(float)$amount;
        }
        $total_value=$this->dashboard423_deposit_format_amount($sum);
    }

    $right_meta=array(
        array('label'=>'DATE', 'value'=>$this->dashboard423_print_header_date($date_value)),
        array('label'=>$code_label, 'value'=>$code_value),
        array('label'=>'REF. NO.', 'value'=>$ref_value)
    );

    $table_rows_html='';
    foreach($detail_rows as $detail_row){
        $table_rows_html.='<tr>';
        foreach($columns as $column){
            $display=$this->dashboard423_print_cell_value($detail_row,$column['key'],$sw);
            $align=$column['key']==='amount' ? ' class="text-right"' : '';
            $table_rows_html.='<td'.$align.'>'.htmlspecialchars((string)$display,ENT_QUOTES,'UTF-8').'</td>';
        }
        $table_rows_html.='</tr>';
    }

    if($table_rows_html===''){
        $table_rows_html='<tr><td colspan="'.max(count($columns),1).'" class="print-empty">No detail lines found.</td></tr>';
    }

    $table_head_html='';
    foreach($columns as $column){
        $align=$column['key']==='amount' ? ' class="text-right"' : '';
        $table_head_html.='<th'.$align.'>'.htmlspecialchars($column['label'],ENT_QUOTES,'UTF-8').'</th>';
    }

    $footer_note='';
    if($sw===6){
        $printed_by='';
        if(isset($_SESSION['user_id'])){
            $printed_by=(string)$_SESSION['user_id'];
        }
        $footer_note='PRINTED '.date('m/d/Y h:i:s A').($printed_by!=='' ? ' BY '.$printed_by : '');
    }

    $signature_html='';
    if($sw===4){
        $signature_html='
        <div class="print-signatures">
            <div class="print-signature-box"><span>REQUESTED BY</span></div>
            <div class="print-signature-box"><span>POSTED BY</span></div>
            <div class="print-signature-box"><span>APPROVED BY</span></div>
            <div class="print-signature-box"><span>RECEIVED BY</span></div>
        </div>';
    }

    $table_class=in_array($sw,array(4,6),true) ? 'print-table-bordered' : 'print-table-compact';

    echo '<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>'.htmlspecialchars($title,ENT_QUOTES,'UTF-8').'</title>
<style>
body{
    margin:0;
    font-family: Arial, Helvetica, sans-serif;
    background:#e9edf2;
    color:#111;
}
.print-shell{
    padding:18px;
}
.print-toolbar{
    width:'.$page_width.';
    margin:0 auto 14px;
    display:flex;
    justify-content:flex-end;
    gap:8px;
}
.print-toolbar button{
    border:1px solid #c8d0da;
    background:#fff;
    color:#1f2d3d;
    padding:8px 16px;
    border-radius:6px;
    font-size:13px;
    cursor:pointer;
}
.print-page{
    width:'.$page_width.';
    min-height:'.$page_min_height.';
    margin:0 auto;
    background:#fff;
    box-shadow:0 14px 40px rgba(15,23,42,.12);
    padding:20mm 18mm 16mm;
    box-sizing:border-box;
}
.print-page-wide{
    padding-bottom:12mm;
}
.print-title{
    text-align:center;
    font-size:24px;
    letter-spacing:6px;
    margin:0 0 22px;
    font-weight:500;
}
.print-header{
    display:grid;
    grid-template-columns:1.2fr .9fr;
    gap:22px;
    align-items:start;
}
.print-meta-row{
    display:flex;
    gap:10px;
    margin-bottom:8px;
    font-size:15px;
    line-height:1.35;
}
.print-meta-label{
    min-width:150px;
    font-weight:600;
    letter-spacing:.3px;
}
.print-meta-value{
    flex:1;
}
.print-meta-right .print-meta-label{
    min-width:110px;
}
.print-detail-wrap{
    margin-top:22px;
}
.print-table{
    width:100%;
    border-collapse:collapse;
    font-size:14px;
}
.print-table thead th{
    font-weight:600;
    padding:8px 10px;
}
.print-table tbody td{
    padding:8px 10px;
    vertical-align:top;
}
.print-table-compact thead th{
    border-bottom:1px solid #555;
}
.print-table-compact tbody td{
    border-bottom:0;
}
.print-table-bordered{
    border:1px solid #666;
}
.print-table-bordered th,
.print-table-bordered td{
    border:1px solid #666;
}
.print-total{
    margin-top:10px;
    display:flex;
    justify-content:flex-end;
    align-items:center;
    gap:18px;
    font-size:15px;
}
.print-total-label{
    font-weight:700;
    letter-spacing:1px;
}
.print-total-value{
    min-width:140px;
    text-align:right;
    font-weight:700;
}
.print-signatures{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:0;
    margin-top:26px;
    border:1px solid #666;
    border-right:0;
}
.print-signature-box{
    min-height:120px;
    border-right:1px solid #666;
    position:relative;
}
.print-signature-box span{
    position:absolute;
    top:10px;
    left:12px;
    font-size:13px;
    font-weight:600;
}
.print-footer-note{
    margin-top:18px;
    text-align:right;
    font-size:11px;
    color:#4b5563;
}
.print-empty{
    text-align:center;
    color:#6b7280;
    padding:24px 12px !important;
}
.text-right{
    text-align:right;
}
@media print{
    @page{
        size: '.$page_size.';
        margin:10mm;
    }
    body{
        background:#fff;
    }
    .print-shell{
        padding:0;
    }
    .print-toolbar{
        display:none;
    }
    .print-page{
        width:auto;
        min-height:auto;
        margin:0;
        box-shadow:none;
        padding:12mm 10mm;
    }
}
</style>
</head>
<body>
<div class="print-shell">
    <div class="print-toolbar">
        <button type="button" onclick="window.print()">Print</button>
        <button type="button" onclick="window.close()">Close</button>
    </div>
    <div class="print-page'.($wide_page ? ' print-page-wide' : '').'">
        <h1 class="print-title">'.htmlspecialchars($title,ENT_QUOTES,'UTF-8').'</h1>
        <div class="print-header">
            <div class="print-meta-left">'.$this->dashboard423_print_meta_block($left_meta).'</div>
            <div class="print-meta-right">'.$this->dashboard423_print_meta_block($right_meta).'</div>
        </div>
        <div class="print-detail-wrap">
            <table class="print-table '.$table_class.'">
                <thead><tr>'.$table_head_html.'</tr></thead>
                <tbody>'.$table_rows_html.'</tbody>
            </table>
            <div class="print-total">
                <div class="print-total-label">TOTAL</div>
                <div class="print-total-value">'.htmlspecialchars($total_value,ENT_QUOTES,'UTF-8').'</div>
            </div>
            '.$signature_html.'
            '.($footer_note!=='' ? '<div class="print-footer-note">'.htmlspecialchars($footer_note,ENT_QUOTES,'UTF-8').'</div>' : '').'
        </div>
    </div>
</div>
</body>
</html>';
}

}

?>
