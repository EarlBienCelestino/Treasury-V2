private function dashboard423_print_cell_value($row,$key,$sw) {
    switch($key){
        case 'bank':
            $value=$this->dashboard423_print_value_from_candidates($row,array('chk_bank','bank'));
            $display=$this->dashboard423_bank_display($value,true);
            return $display!=='' ? $display : trim((string)$value);

        case 'branch':
            $value=$this->dashboard423_print_value_from_candidates($row,array('branch'));
            return $this->dashboard423_branch_display($value);

        case 'customer':
            if(isset($row['customer']) && trim((string)$row['customer'])!==''){
                return $this->dashboard423_payee_display($row['customer']);
            }
            if(isset($row['cd_party']) && trim((string)$row['cd_party'])!==''){
                return $this->dashboard423_party_display($row['cd_party']);
            }
            return '';

        case 'type':
            return $this->dashboard423_print_type_value($row,(int)$sw);

        case 'account':
            $value=$this->dashboard423_print_value_from_candidates($row,array('acct_no','account'));
            return trim((string)$value);

        case 'check_no':
            $value=$this->dashboard423_print_value_from_candidates($row,array('chk_no','ref_no','code'));
            return trim((string)$value);

        case 'check_date':
            $value=$this->dashboard423_print_value_from_candidates($row,array('chk_dt','ddate','date','date_'));
            return $this->dashboard423_print_detail_date($value);

        case 'amount':
            $value=$this->dashboard423_print_value_from_candidates($row,array('amount','total','check','cash'));
            return $this->dashboard423_deposit_format_amount($value);
    }

    return '';
}

