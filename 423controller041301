}

private function dashboard423_salesman_row($salesman_value) {
    $salesman_value=trim((string)$salesman_value);
    if($salesman_value===''){ return array(); }

    if(!$this->db->table_exists('salesman')){
        return array();
    }

    $fields=$this->db->list_fields('salesman');
    $query=$this->db->select('code,name');
    if(ctype_digit($salesman_value) && in_array('id',$fields,true)){
        $query->where('id',$salesman_value);
    }
    else if(in_array('code',$fields,true)) {
        $query->where('code',$salesman_value);
    }
    else {
        return array();
    }

    $row=$query->get('salesman')->row_array();
    if(!$row && ctype_digit($salesman_value) && in_array('code',$fields,true)){
        $row=$this->db
            ->select('code,name')
            ->where('code',$salesman_value)
            ->get('salesman')
            ->row_array();
    }
    if(!$row){ $row=array(); }

    return $row;
}

private function dashboard423_salesman_display($salesman_value) {
    $row=$this->dashboard423_salesman_row($salesman_value);
    if(isset($row['code']) && trim((string)$row['code'])!==''){
        $code=trim((string)$row['code']);
        $name=isset($row['name']) ? trim((string)$row['name']) : '';
        return $code.($name!=='' ? ' - '.$name : '');
    }

    return trim((string)$salesman_value);
}

