private function collh_next_numeric_series($field,$step,$default_value) {
    $rows=$this->db
        ->select($field)
        ->order_by('id','desc')
        ->limit(10)
        ->get('collh')
        ->result_array();

    $length=strlen($default_value);
    $last_value=intval($default_value) - $step;

    foreach($rows as $row){
        $value=trim((string)$row[$field]);
        if($value!=='' && ctype_digit($value)){
            $length=strlen($value);
            $last_value=intval($value);
            break;
        }
    }

    return str_pad((string)($last_value + $step), $length, '0', STR_PAD_LEFT);
}

private function collh_next_code() {
    return $this->collh_next_numeric_series('code',1,'0000000001');
}

private function collh_next_ref_no() {
    return $this->collh_next_numeric_series('ref_no',10,'00000010');
}

private function dashboard423_jv_sequence_from_value($value) {
    $value=strtoupper(trim((string)$value));
    if($value===''){ return 0; }

    if(preg_match('/^JV(\d+)$/', $value, $m)){
        return intval($m[1]);
    }

    $digits=preg_replace('/\D+/', '', $value);
    if($digits===''){ return 0; }

    return intval($digits);
}

private function dashboard423_jv_max_sequence_in_table($table,$field) {
    if(!$this->db->table_exists($table)){ return 0; }

    $fields=$this->db->list_fields($table);
    if(!in_array($field,$fields,true)){ return 0; }

    $rows=$this->db
        ->select($field)
        ->like($field,'JV','after')
        ->order_by('id','desc')
        ->limit(10)
        ->get($table)
        ->result_array();

    $maxSeq=0;
    foreach($rows as $row){
        $seq=$this->dashboard423_jv_sequence_from_value(isset($row[$field]) ? $row[$field] : '');
        if($seq>$maxSeq){ $maxSeq=$seq; }
    }

    return $maxSeq;
}

private function dashboard423_next_jv_code() {
    $seq=max(
        $this->dashboard423_jv_max_sequence_in_table('glh','code'),
        $this->dashboard423_jv_max_sequence_in_table('glh','doc_code'),
        $this->dashboard423_jv_max_sequence_in_table('collh','jv_no')
    ) + 1;

    return 'JV'.str_pad($seq, 8, '0', STR_PAD_LEFT);
}

private function dashboard423_insert_pr_jv_header($collhData,$jvCode) {
    if(!$this->db->table_exists('glh')){
        return array('success'=>false,'message'=>'Journal Voucher header table was not found.');
    }

    $fields=$this->db->list_fields('glh');
    $glh=array();
    $date_=isset($collhData['date_']) ? trim((string)$collhData['date_']) : '';
    if($date_===''){ $date_=date('Y-m-d'); }

    $particulars=strtoupper(trim((string)(isset($collhData['remarks']) ? $collhData['remarks'] : '')));
    if($particulars===''){
        $particulars='PROVISIONAL RECEIPT';
    }

    $prCode=trim((string)(isset($collhData['code']) ? $collhData['code'] : ''));
    $prRefNo=trim((string)(isset($collhData['ref_no']) ? $collhData['ref_no'] : ''));
    $voucherNo=$prCode!=='' ? 'PR'.$prCode : $jvCode;
    $refNoDoc=$prRefNo!=='' ? 'PR'.$prRefNo : $voucherNo;

    if(in_array('code',$fields,true)){ $glh['code']=$jvCode; }
    if(in_array('date_',$fields,true)){ $glh['date_']=$date_; }
    if(in_array('doc_code',$fields,true)){ $glh['doc_code']=$jvCode; }
    if(in_array('no_ref',$fields,true)){ $glh['no_ref']=$voucherNo; }
    if(in_array('am_dr',$fields,true)){ $glh['am_dr']=number_format(0,2,'.',''); }
    if(in_array('am_cr',$fields,true)){ $glh['am_cr']=number_format(0,2,'.',''); }
    if(in_array('cancel',$fields,true)){ $glh['cancel']=0; }
    if(in_array('source',$fields,true)){ $glh['source']=null; }
    if(in_array('dt_refdoc',$fields,true)){ $glh['dt_refdoc']=$date_; }
    if(in_array('no_refdoc',$fields,true)){ $glh['no_refdoc']=$refNoDoc; }
    if(in_array('ty_tran',$fields,true)){ $glh['ty_tran']='03'; }
    if(in_array('particulars',$fields,true)){ $glh['particulars']=$particulars; }
    if(in_array('void',$fields,true)){ $glh['void']=0; }

    $this->db->insert('glh',$glh);

    if($this->db->affected_rows()<=0){
        return array('success'=>false,'message'=>'Unable to create the Journal Voucher header.');
    }

    return array(
        'success'=>true,
        'id'=>$this->db->insert_id()
    );
}

private function collh_customer_row($customer_value) {
    $customer_value=trim((string)$customer_value);
    if($customer_value===''){ return array(); }

    $row=$this->db
        ->select('id,code,name')
        ->where('code',$customer_value)
        ->get('customer')
        ->row_array();

    if(!$row && ctype_digit($customer_value)){
        $row=$this->db
            ->select('id,code,name')
            ->where('id',$customer_value)
            ->get('customer')
            ->row_array();
    }

    if(!$row){ $row=array(); }

    return $row;
}

private function collh_customer_code($customer_value) {
    $row=$this->collh_customer_row($customer_value);
    if(isset($row['code']) && $row['code']!==''){ return $row['code']; }
    return trim((string)$customer_value);
}

