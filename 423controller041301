private function dashboard423_check_detail_source_text($row) {
    $flags=array(
        'chk'=>'Check',
        'csh'=>'Cash',
        'chkcsh'=>'Check/Cash'
    );

    foreach($flags as $field=>$label){
        $value=strtoupper(trim((string)(isset($row[$field]) ? $row[$field] : '')));
        if($value==='TRUE' || $value==='1' || $value==='Y'){
            return $label;
        }
    }

    return trim((string)(isset($row['type']) ? $row['type'] : ''));
}

private function dashboard423_check_detail_location_text($row) {
