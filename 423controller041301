function validate_pr_form(){
    var errors=[];
    var firstSelector="";
    var cash=parseFloat($("#pr_cash").val() || 0);
    var checks=parseFloat($("#pr_checks").val() || 0);
    var total=(isNaN(cash) ? 0 : cash) + (isNaN(checks) ? 0 : checks);

    function addError(selector,message){
        errors.push(message);
        mark_pr_invalid(selector);
        if(firstSelector===""){ firstSelector=selector; }
    }

    reset_pr_validation();

    if($.trim($("#pr_date").val() || "")===""){ addError("#pr_date","Date is required."); }
    if($.trim($("#pr_code").val() || "")===""){ addError("#pr_code","P.R No. is required."); }
    if($.trim($("#pr_ref_no").val() || "")===""){ addError("#pr_ref_no","Ref No. is required."); }
    if($.trim($("#pr_customer").val() || "")===""){ addError("#pr_customer","Customer is required."); }
    if($("#pr_type_others").is(":checked") && $.trim($("#pr_account").val() || "")===""){
        addError("#pr_account","Account is required for Others.");
    }
    if($.trim($("#pr_remarks_text").val() || "")===""){ addError("#pr_remarks_text","Remarks is required."); }
    if(!(total>0)){
        addError("#pr_cash","Cash or checks must be greater than zero.");
        mark_pr_invalid("#pr_checks");
    }

    if(firstSelector!==""){
        $(firstSelector).focus();
    }

    return {
        ok: errors.length===0,
        message: errors.join("\\n")
    };
}

