private function dashboard423_increment_suffix_value($value,$default_value) {
    $value=trim((string)$value);
    if($value==='' || !preg_match('/^(.*?)(\d+)$/',$value,$matches)){
        return $default_value;
    }

    return $matches[1].str_pad((string)(intval($matches[2]) + 1),strlen($matches[2]),'0',STR_PAD_LEFT);
}

private function dashboard423_check_module_next_ref_no($sw) {
    $config=$this->dashboard423_check_module_config($sw);
    if(!$config){ return ''; }

    $defaults=array(
        3=>'B-001',
        4=>'04-001',
        5=>'P-001',
        6=>'01-001'
    );
    $default_value=isset($defaults[(int)$sw]) ? $defaults[(int)$sw] : '';

    $rows=$this->db
        ->select('ref_no')
        ->order_by('id','desc')
        ->limit(10)
        ->get($config['header'])
        ->result_array();

    foreach($rows as $row){
        $ref_no=trim((string)(isset($row['ref_no']) ? $row['ref_no'] : ''));
        if($ref_no!==''){
            return $this->dashboard423_increment_suffix_value($ref_no,$default_value);
        }
    }

    return $default_value;
}

