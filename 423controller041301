function Fin() {
    $id=intval($this->input->post('id'));
    $sw=intval($this->input->post('sw'));
    $module=strtolower(trim((string)$this->input->post('module')));
    $table='';

    if($id<=0){
        echo json_encode(array('success'=>false,'message'=>'Invalid transaction.'));
        return;
    }

    $module_map=array(
        'pr'=>'collh',
        'collh'=>'collh',
        'deposit'=>'dsh',
        'dsh'=>'dsh',
        'outcheck'=>'chk_och',
        'chk_och'=>'chk_och',
        'bounced'=>'chk_bch',
        'chk_bch'=>'chk_bch',
        'nullified'=>'chk_nch',
        'chk_nch'=>'chk_nch',
        'pullout'=>'chk_pch',
        'pull-out'=>'chk_pch',
        'chk_pch'=>'chk_pch',
        'cleared'=>'chk_cch',
        'chk_cch'=>'chk_cch'
    );

    if(isset($module_map[$module])){
        $table=$module_map[$module];
    }
    else {
        $matches=array();
        foreach(array('collh','dsh','chk_och','chk_bch','chk_nch','chk_pch','chk_cch') as $candidate){
            if(!$this->db->table_exists($candidate)){ continue; }
            if($this->db->where('id',$id)->count_all_results($candidate)>0){
                $matches[]=$candidate;
            }
        }

        if(count($matches)===1){
            $table=$matches[0];
        }
    }

    if($table===''){
        echo json_encode(array('success'=>false,'message'=>'Unable to determine the transaction type.'));
        return;
    }

    $fields=$this->db->list_fields($table);
    if(!in_array('fin',$fields)){
        echo json_encode(array('success'=>false,'message'=>'Finalize is not available for this transaction.'));
        return;
    }

    if(!$this->dashboard423_table_has_field($table,'fin')){
        echo json_encode(array('success'=>false,'message'=>'Finalize is not available for this module.'));
        return;
    }

    $this->db->where('id',$id)->update($table,array('fin'=>$sw>0 ? 1 : 0));

    echo json_encode(array('success'=>true));
}

