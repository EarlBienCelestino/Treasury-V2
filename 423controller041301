    <script>
    (function(){
        var finalized = <?=json_encode($fin)?>;

        function initOutcheckSelectors(){
            if($("#outcheck_detail_bank").length && !$("#outcheck_detail_bank").hasClass("select2-hidden-accessible")){
                $("#outcheck_detail_bank").select2({
                    ajax: {
                        url: "<?=base_url("423/dashboard/mf/outcheck_bank")?>",
                        type: "post",
                        dataType: "json",
                        delay: 250,
                        data: function(params){ return { searchTerm: params.term }; },
                        processResults: function(response){ return { results: response }; },
                        cache: true
                    }
                });
            }

            if($("#outcheck_detail_customer").length && !$("#outcheck_detail_customer").hasClass("select2-hidden-accessible")){
                $("#outcheck_detail_customer").select2({
                    ajax: {
                        url: "<?=base_url("423/dashboard/mf/outcheck_customer")?>",
                        type: "post",
                        dataType: "json",
                        delay: 250,
                        data: function(params){ return { searchTerm: params.term }; },
                        processResults: function(response){ return { results: response }; },
                        cache: true
                    }
                });
            }
        }

        function setOutcheckSelectValue(selector, value, text){
            var $select = $(selector);

            if(!value){
                $select.val(null).trigger("change");
                return;
            }

            $select.find("option").remove();
            var option = new Option(text, value, true, true);
            $select.append(option).trigger("change");
        }

        function setOutcheckType(value){
            $(".outcheck-type-check").prop("checked", false);
            if(value){
                $("#outcheck_type_" + value).prop("checked", true);
            }
        }

        function getOutcheckType(){
            return $(".outcheck-type-check:checked").first().val() || "";
        }

        function currentOutcheckState(){
            return {
                seq: $("#outcheck_detail_seq").val() || "0",
                id: $("#outcheck_detail_parent_id").val() || "0",
                bank: $("#outcheck_detail_bank").val() || "",
                chk_no: $.trim($("#outcheck_detail_chk_no").val() || ""),
                chk_dt: $("#outcheck_detail_chk_dt").val() || "",
                acct_no: $.trim($("#outcheck_detail_acct_no").val() || ""),
                branch: $.trim($("#outcheck_detail_branch").val() || ""),
                type_key: getOutcheckType(),
                customer: $("#outcheck_detail_customer").val() || "",
                amount: $("#outcheck_detail_amount").val() || "0.00"
            };
        }

        window.clearOutcheckDetailForm = function(forceClear){
            var state = currentOutcheckState();
            var hasValue = state.seq !== "0" || state.bank !== "" || state.chk_no !== "" || state.chk_dt !== "" || state.acct_no !== "" || state.branch !== "" || state.type_key !== "" || state.customer !== "" || parseFloat(state.amount || 0) > 0;

            if(!forceClear && hasValue && !confirm("Clear the current check entry?")){
                return;
            }

            $("#outcheck_detail_seq").val("0");
            $("#outcheck_detail_chk_no").val("");
            $("#outcheck_detail_chk_dt").val("");
            $("#outcheck_detail_acct_no").val("");
            $("#outcheck_detail_branch").val("");
            $("#outcheck_detail_amount").val("0.00");
            setOutcheckType("");

            if($("#outcheck_detail_bank").hasClass("select2-hidden-accessible")){
                $("#outcheck_detail_bank").val(null).trigger("change");
            }

            if($("#outcheck_detail_customer").hasClass("select2-hidden-accessible")){
                $("#outcheck_detail_customer").val(null).trigger("change");
            }
        };

        window.fillOutcheckDetailForm = function(record){
            if(!record){ return; }

            $("#outcheck_detail_seq").val(record.seq || 0);
            $("#outcheck_detail_chk_no").val(record.chk_no || "");
            $("#outcheck_detail_chk_dt").val(record.chk_dt || "");
            $("#outcheck_detail_acct_no").val(record.acct_no || "");
            $("#outcheck_detail_branch").val(record.branch || "");
            $("#outcheck_detail_amount").val(record.amount || "0.00");
            setOutcheckType(record.type_key || "");
            setOutcheckSelectValue("#outcheck_detail_bank", record.chk_bank_id || "", record.bank_display || "");
            setOutcheckSelectValue("#outcheck_detail_customer", record.customer_value || "", record.customer_display || "");
        };

        function validateOutcheckDetail(){
            var state = currentOutcheckState();
            var errors = [];

            if(state.bank === ""){ errors.push("Please select the bank."); }
            if(state.chk_no === ""){ errors.push("Please enter the check no."); }
            if(state.chk_dt === ""){ errors.push("Please enter the check date."); }
            if(state.acct_no === ""){ errors.push("Please enter the account no."); }
            if(state.branch === ""){ errors.push("Please enter the branch."); }
            if(state.type_key === ""){ errors.push("Please choose the check type."); }
            if(state.customer === ""){ errors.push("Please select the customer."); }

            var amount = parseFloat(state.amount || 0);
            if(!(amount > 0)){ errors.push("Amount must be greater than zero."); }

            return errors;
        }

        window.saveOutcheckDetail = function(){
            if(finalized > 0){
                alert("This out-check is finalized.");
                return;
            }

            var errors = validateOutcheckDetail();
            if(errors.length > 0){
                alert(errors.join("\n"));
                return;
            }

            if(!confirm("Are you sure to save this check entry?")){
                return;
            }

            $.ajax({
                url: "<?=base_url("423/dashboard/save_outcheck_detail")?>",
                method: "POST",
                data: { datas: currentOutcheckState() },
                success: function(raw){
                    var res = {};

                    try { res = JSON.parse(raw); }
                    catch(err) { res = { success: false, message: "Unable to save the check entry." }; }

                    if(!res.success){
                        if(res.message){ alert(res.message); }
                        return;
                    }

                    if(typeof refreshOutcheckTotals === "function"){
                        refreshOutcheckTotals(res.total);
                    }

                    if(typeof loadOutcheckDetails === "function"){
                        loadOutcheckDetails();
                    }
                }
            });
        };

        window.deleteOutcheckDetail = function(){
            if(finalized > 0){
                alert("This out-check is finalized.");
                return;
            }

            var seq = $("#outcheck_detail_seq").val() || "0";
            if(parseInt(seq, 10) <= 0){
                alert("Please select a check entry to delete.");
                return;
            }

            if(!confirm("Are you sure to delete this check entry?")){
                return;
            }

            $.ajax({
                url: "<?=base_url("423/dashboard/delete_outcheck_detail")?>",
                method: "POST",
                data: {
                    seq: seq,
                    id: $("#outcheck_detail_parent_id").val() || "0"
                },
                success: function(raw){
                    var res = {};

                    try { res = JSON.parse(raw); }
                    catch(err) { res = { success: false, message: "Unable to delete the check entry." }; }

                    if(!res.success){
                        if(res.message){ alert(res.message); }
                        return;
                    }

                    if(typeof refreshOutcheckTotals === "function"){
                        refreshOutcheckTotals(res.total);
                    }

                    if(typeof loadOutcheckDetails === "function"){
                        loadOutcheckDetails();
                    }
                }
            });
        };

        $("#outcheck_detail_bank")
            .off(".outcheckDetail")
            .on("select2:select.outcheckDetail", function(){
                if(finalized > 0){ return; }

                $.ajax({
                    url: "<?=base_url("423/dashboard/outcheck_bank_branch")?>",
                    method: "POST",
                    data: { bank_id: $("#outcheck_detail_bank").val() || "" },
                    success: function(raw){
                        var res = {};

                        try { res = JSON.parse(raw); }
                        catch(err) { res = {}; }

                        $("#outcheck_detail_branch").val(res.branch || "");
                    }
                });
            });

        $(".outcheck-type-check")
            .off(".outcheckDetail")
            .on("change.outcheckDetail", function(){
                if($(this).is(":checked")){
                    $(".outcheck-type-check").not(this).prop("checked", false);
                }
            });

        initOutcheckSelectors();

        $("#outcheck_details_table").DataTable({
            scrollX: true,
            order: [[0, "desc"]]
        });

        $("#outcheck_details_table tbody")
            .off("click", "tr")
            .on("click", "tr", function(){
                var payload = $(this).attr("data-record") || "{}";

                try { payload = JSON.parse(payload); }
                catch(err) { payload = {}; }

                fillOutcheckDetailForm(payload);
            });
    })();
    </script>
    <?php
    return ob_get_clean();
}

