private function dashboard423_check_module_format_value($format,$value,$row=array()) {
    $raw=trim((string)$value);

    if($format==='amount'){
        return $this->dashboard423_deposit_format_amount($value);
    }

    if($format==='party'){
        $display=$this->dashboard423_party_display($raw);
        return $display!=='' ? $display : $raw;
    }

    if($format==='customer'){
        $display=$this->collh_customer_display($raw);
        return $display!=='' ? $display : $raw;
    }

    if($format==='salesman'){
        $display=$this->dashboard423_salesman_display($raw);
        return $display!=='' ? $display : $raw;
    }

    if($format==='account'){
        $display=$this->collh_account_display($raw);
        return $display!=='' ? $display : $raw;
    }

    if($format==='bank'){
        $display=$this->dashboard423_bank_display($raw);
        return $display!=='' ? $display : $raw;
    }

    if($format==='source'){
        $display=$this->dashboard423_check_detail_source_text($row);
        return $display!=='' ? $display : $raw;
    }

    if($format==='location'){
        $display=$this->dashboard423_check_detail_location_text($row);
        return $display!=='' ? $display : $raw;
    }

    return $raw;
}

private function dashboard423_render_check_module_edit_field($field_config,$row,$table,$is_finalized=false) {
    $field=$field_config['field'];
    if(!$this->dashboard423_table_has_field($table,$field)){ return ''; }

    $label=htmlspecialchars($field_config['label'],ENT_QUOTES,'UTF-8');
    $mode=isset($field_config['mode']) ? $field_config['mode'] : 'readonly';
    $format=isset($field_config['format']) ? $field_config['format'] : '';
    $input=isset($field_config['input']) ? $field_config['input'] : 'text';
    $wrap_class=isset($field_config['wrap_class']) ? trim((string)$field_config['wrap_class']) : 'col-lg-4 col-md-6 col-sm-12';
    $input_class=isset($field_config['input_class']) ? ' '.trim((string)$field_config['input_class']) : '';
    $rows=max(2,intval(isset($field_config['rows']) ? $field_config['rows'] : 3));
    $value=isset($row[$field]) ? $row[$field] : '';
    $display=$format!=='' ? $this->dashboard423_check_module_format_value($format,$value,$row) : trim((string)$value);
    if($display===''){ $display=trim((string)$value); }
    $id='legacy_check_'.preg_replace('/[^a-z0-9_]+/i','_',$field);
    $editable=($mode==='editable' && !$is_finalized);

    $html='
        <div class="'.$wrap_class.'">
            <div class="input-group input-group-sm txn-inline-group">
                <div class="input-group-prepend"><span class="input-group-text">'.$label.'</span></div>';

    if($editable && $input==='textarea'){
        $html.='<textarea class="form-control legacy-check-value'.$input_class.'" rows="'.$rows.'" id="'.$id.'" onchange="dashboard423CheckFieldSave(\''.htmlspecialchars($field,ENT_QUOTES,'UTF-8').'\')">'
            .htmlspecialchars(trim((string)$value),ENT_QUOTES,'UTF-8')
            .'</textarea>';
    }
    else if($editable){
        $html.='<input type="'.$input.'" class="form-control legacy-check-value'.$input_class.'" id="'.$id.'" value="'
            .htmlspecialchars(trim((string)$value),ENT_QUOTES,'UTF-8')
            .'" onchange="dashboard423CheckFieldSave(\''.htmlspecialchars($field,ENT_QUOTES,'UTF-8').'\')">';
    }
    else if($input==='textarea'){
        $html.='<textarea class="form-control legacy-check-value'.$input_class.'" rows="'.$rows.'" id="'.$id.'" readonly>'
            .htmlspecialchars($display,ENT_QUOTES,'UTF-8')
            .'</textarea>';
    }
    else {
        $html.='<input type="text" class="form-control legacy-check-value'.$input_class.'" id="'.$id.'" value="'
            .htmlspecialchars($display,ENT_QUOTES,'UTF-8')
            .'" readonly>';
    }

    $html.='
            </div>
        </div>';

    return $html;
}

private function dashboard423_render_check_module_edit($sw,$id) {
    $config=$this->dashboard423_check_module_config($sw);
    if(!$config){ return '<div class="alert alert-warning">Module configuration was not found.</div>'; }

    $header_table=$config['header'];
    $row=$this->db->where('id',$id)->get($header_table)->row_array();
    if(!$row){
        return '<div class="alert alert-warning">The selected '.$config['title'].' record was not found.</div>';
    }

    $is_finalized=(isset($row['fin']) && intval($row['fin'])>0) ? 1 : 0;
    $module_key=$this->dashboard423_check_module_module_key($sw);
    $fin_enabled=$this->dashboard423_table_has_field($header_table,'fin');
    $fields_html='';
    $editable_fields=array();
    foreach($config['fields'] as $field_config){
        if(isset($field_config['mode']) && $field_config['mode']==='editable'){
            $editable_fields[]=$field_config['field'];
        }
        $fields_html.=$this->dashboard423_render_check_module_edit_field($field_config,$row,$header_table,$is_finalized>0);
