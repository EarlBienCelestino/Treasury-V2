private function dashboard423_outcheck_next_ref_no($date_value='') {
    $date_value=trim((string)$date_value);
    $stamp=$date_value!=='' ? strtotime($date_value) : false;

    if($stamp===false){
        $stamp=time();
    }

    $prefix='OG'.date('y-m',$stamp);
    $rows=$this->db
        ->select('ref_no')
        ->like('ref_no',$prefix,'after')
        ->order_by('id','desc')
        ->limit(10)
        ->get('chk_och')
        ->result_array();

    $last_number=0;

    foreach($rows as $row){
        $ref_no=trim((string)(isset($row['ref_no']) ? $row['ref_no'] : ''));
        if(preg_match('/^'.preg_quote($prefix,'/').'-(\d{1,3})$/',$ref_no,$matches)){
            $last_number=max($last_number,intval($matches[1]));
        }
    }

    return $prefix.'-'.str_pad((string)($last_number + 1),2,'0',STR_PAD_LEFT);
}

