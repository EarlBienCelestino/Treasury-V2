    $sum_row=$this->db
        ->select_sum('amount')
        ->where('id',$id)
        ->get('colld')
        ->row_array();

    $check_total=isset($sum_row['amount']) ? (float)$sum_row['amount'] : 0;
    $cash_total=isset($header['cash']) ? (float)$header['cash'] : 0;
    $totals=array(
        'cash'=>$this->dashboard423_deposit_format_amount($cash_total),
        'check'=>$this->dashboard423_deposit_format_amount($check_total),
        'total'=>$this->dashboard423_deposit_format_amount($cash_total + $check_total)
    );

    $fields=$this->db->list_fields('collh');
    $data=array();

    if(in_array('check',$fields,true)){ $data['check']=$totals['check']; }
    if(in_array('total',$fields,true)){ $data['total']=$totals['total']; }

    if(count($data)>0){
        $this->db->where('id',$id)->update('collh',$data);
    }

    return $totals;
}

private function dashboard423_pr_type_text($row) {
    $others=strtoupper(trim((string)(isset($row['others']) ? $row['others'] : '')));
    $replaced=strtoupper(trim((string)(isset($row['replaced']) ? $row['replaced'] : '')));
    $collection=strtoupper(trim((string)(isset($row['collection']) ? $row['collection'] : '')));
    $type_=strtoupper(trim((string)(isset($row['type_']) ? $row['type_'] : '')));

    if($others==='TRUE' || $type_==='OTH'){ return 'Others'; }
    if($replaced==='TRUE' || $type_==='REP'){ return 'Replacement'; }
    if($collection==='TRUE' || $type_==='COL'){ return 'Collection'; }

    $pr_type=intval(isset($row['pr_type']) ? $row['pr_type'] : -1);
    if($pr_type===0){ return 'Collection'; }
    if($pr_type===1){ return 'Replacement'; }
    if($pr_type===2){ return 'Others'; }

    return 'Others';
}

