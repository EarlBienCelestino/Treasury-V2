private function dashboard423_check_register_rows($qs,$ds,$de) {
    $qs=trim((string)$qs);
    $rows=array();
    $sources=array(
        array('detail'=>'colld','header'=>'collh'),
        array('detail'=>'dsd','header'=>'dsh'),
        array('detail'=>'chk_ocd','header'=>'chk_och'),
        array('detail'=>'chk_bcd','header'=>'chk_bch'),
        array('detail'=>'chk_ncd','header'=>'chk_nch'),
        array('detail'=>'chk_pcd','header'=>'chk_pch'),
        array('detail'=>'chk_ccd','header'=>'chk_cch')
    );

    foreach($sources as $source){
        if(!$this->db->table_exists($source['detail']) || !$this->db->table_exists($source['header'])){
            continue;
        }

        $detail_fields=$this->db->list_fields($source['detail']);
        $header_fields=$this->db->list_fields($source['header']);
        $payee_field_sql="''";

        if(in_array('customer',$detail_fields)){ $payee_field_sql='d.customer'; }
        else if(in_array('customer',$header_fields)){ $payee_field_sql='h.customer'; }
        else if(in_array('cd_party',$header_fields)){ $payee_field_sql='h.cd_party'; }

        $query=$this->db
            ->select("d.chk_bank AS bank_code,d.chk_no,d.chk_dt,d.amount,{$payee_field_sql} AS payee_value,h.code AS tran_code,h.ref_no",FALSE)
            ->from($source['detail'].' d')
            ->join($source['header'].' h','h.id=d.id','left')
            ->join('bank b','CAST(b.id AS CHAR) = d.chk_bank OR b.code = d.chk_bank','left',FALSE);

        if($qs!==''){
            $query->group_start()
                ->like('d.chk_no',$qs)
                ->or_like('d.acct_no',$qs)
                ->or_like('d.amount',$qs)
                ->or_like('b.name',$qs)
                ->or_like('h.code',$qs)
                ->or_like('h.ref_no',$qs);

            if($payee_field_sql!="''"){
                $query->or_like($payee_field_sql,$qs);
            }

            $query->group_end();
        }

        $this->dashboard423_apply_date_range('d.chk_dt',$ds,$de);

        $source_rows=$query->get()->result_array();
        foreach($source_rows as $row){
            $bank_name=$this->dashboard423_bank_display(isset($row['bank_code']) ? $row['bank_code'] : '');
            if($bank_name===''){ $bank_name=trim((string)$row['bank_code']); }

            $rows[]=array(
                'bank_name'=>$bank_name,
                'chk_no'=>trim((string)$row['chk_no']),
                'chk_dt'=>trim((string)$row['chk_dt']),
                'payee'=>$this->dashboard423_payee_display(isset($row['payee_value']) ? $row['payee_value'] : ''),
                'amount'=>isset($row['amount']) ? $row['amount'] : '0.00'
            );
        }
    }

    usort($rows,function($row_a,$row_b){
        $date_a=strtotime(isset($row_a['chk_dt']) ? $row_a['chk_dt'] : '');
        $date_b=strtotime(isset($row_b['chk_dt']) ? $row_b['chk_dt'] : '');

        if($date_a==$date_b){
            return strcmp((string)$row_b['chk_no'],(string)$row_a['chk_no']);
        }

        return ($date_a < $date_b) ? 1 : -1;
    });

    return array_slice($rows,0,200);
}

private function dashboard423_next_numeric_series($table,$field,$step,$default_value) {
    $rows=$this->db
        ->select($field)
        ->order_by('id','desc')
        ->limit(10)
        ->get($table)
        ->result_array();

    $length=strlen($default_value);
    $last_value=intval($default_value) - $step;

    foreach($rows as $row){
        $value=trim((string)(isset($row[$field]) ? $row[$field] : ''));
        if($value!=='' && ctype_digit($value)){
            $length=strlen($value);
            $last_value=intval($value);
            break;
        }
    }

    return str_pad((string)($last_value + $step), $length, '0', STR_PAD_LEFT);
}

