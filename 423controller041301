private function dashboard423_apply_date_range($field,$start_date,$end_date) {
    $start_date=trim((string)$start_date);
    $end_date=trim((string)$end_date);

    if($start_date!=='' && $end_date!=='' && $start_date>$end_date){
        $tmp=$start_date;
        $start_date=$end_date;
        $end_date=$tmp;
    }

    if($start_date!==''){
        $this->db->where($field.' >=',$start_date);
    }

    if($end_date!==''){
        $this->db->where($field.' <=',$end_date);
    }
}

