function save_collh() {
    $tmp=$this->input->post('datas');
    $fld=$this->db->list_fields('collh');
    $data=array();
    $errors=array();

    foreach($fld as $field){
        if($field!='id'){
            $data[$field]='';
        }
    }

    $pr_type_name='others';
    if(isset($tmp['pr_type_name']) && strlen(trim($tmp['pr_type_name']))>0){
        $pr_type_name=strtolower(trim($tmp['pr_type_name']));
    }

    $cash=isset($tmp['cash']) ? floatval($tmp['cash']) : 0;
    $check=isset($tmp['check']) ? floatval($tmp['check']) : 0;
    $total=$cash + $check;

    $data['date_']=isset($tmp['date_']) ? trim($tmp['date_']) : '';
    if($data['date_']==''){ $data['date_']=date('Y-m-d'); }

    $data['code']=isset($tmp['code']) ? trim($tmp['code']) : '';
    if($data['code']==''){ $data['code']=$this->collh_next_code(); }

    $data['ref_no']=isset($tmp['ref_no']) ? trim($tmp['ref_no']) : '';
    if($data['ref_no']==''){ $data['ref_no']=$this->collh_next_ref_no(); }

    $data['customer']=$this->collh_customer_code(isset($tmp['customer']) ? $tmp['customer'] : '');
    $data['salesman']='OFFICE';
    $data['account']='';
    $remarks_text=isset($tmp['remarks_text']) ? trim($tmp['remarks_text']) : '';
    $raw_account=isset($tmp['account']) ? trim($tmp['account']) : '';
    $data['remarks']='PR'.$data['ref_no'];
    if($remarks_text!==''){
        $data['remarks'].=' '.$remarks_text;
    }
    $data['cash']=number_format($cash,2,'.','');
    $data['check']=number_format($check,2,'.','');
    $data['total']=number_format($total,2,'.','');

    $data['collection']='FALSE';
    $data['replaced']='FALSE';
    $data['others']='FALSE';
    $data['pr_type']=2;
    $data['type_']='OTH';

    if($data['date_']===''){ $errors[]='Date is required.'; }
    if($data['code']===''){ $errors[]='P.R No. is required.'; }
    if($data['ref_no']===''){ $errors[]='Ref No. is required.'; }
    if($data['customer']===''){ $errors[]='Customer is required.'; }
    if($remarks_text===''){ $errors[]='Remarks is required.'; }
    if($total<=0){ $errors[]='Cash or checks must be greater than zero.'; }

    if($pr_type_name=='collection'){
        $data['collection']='TRUE';
        $data['pr_type']=0;
        $data['type_']='COL';
    }
    else if($pr_type_name=='replacement'){
        $data['replaced']='TRUE';
        $data['pr_type']=1;
        $data['type_']='REP';
    }
    else {
        $data['others']='TRUE';
        $data['pr_type']=2;
        $data['type_']='OTH';
        $account_value=$raw_account;
        $account_row=$this->collh_account_row($account_value);
        if(isset($account_row['code']) && $account_row['code']!==''){
            $data['account']=$account_row['code'];
        }
        else {
            $data['account']=$account_value;
        }
        if(trim((string)$data['account'])===''){
            $errors[]='Account is required for Others.';
        }
    }

    if(count($errors)>0){
        echo json_encode(array(
            'success'=>false,
            'message'=>implode("\n",$errors)
        ));
        return;
    }

    $jvCode=$this->dashboard423_next_jv_code();
    if(in_array('jv_dt',$fld,true)){ $data['jv_dt']=$data['date_']; }
    if(in_array('jv_no',$fld,true)){ $data['jv_no']=$jvCode; }

    $this->db->trans_begin();
    $this->db->insert('collh',$data);
    $collhId=$this->db->insert_id();

    $jvResult=$this->dashboard423_insert_pr_jv_header($data,$jvCode);
    if(!$jvResult['success']){
        $this->db->trans_rollback();
        echo json_encode(array(
            'success'=>false,
            'message'=>$jvResult['message']
        ));
        return;
    }

    if($this->db->trans_status()===false){
        $this->db->trans_rollback();
        echo json_encode(array(
            'success'=>false,
            'message'=>'Unable to save provisional receipt.'
        ));
        return;
    }

    $this->db->trans_commit();

    echo json_encode(array(
        'success'=>true,
        'id'=>$collhId,
        'code'=>$data['code'],
        'jv_no'=>$jvCode
    ));
} 

