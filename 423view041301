window.dashboard423OpenPrint = function(sw, id) {
    sw = parseInt(sw || 0, 10);
    id = parseInt(id || 0, 10);

    if(!(id > 0)) {
        alert("Please select a valid transaction to print.");
        return;
    }

    window.open("<?=site_url('423/dashboard/print_view')?>/" + sw + "/" + id, "_blank");
};

function  qs() {
    
    $.ajax({url:"<?=base_url('423/dashboard/list')?>"
    ,method:"POST",data:{ qs:$("#qs").val() }
    ,success:function(data) { $("#form_entry").empty(); $("#list").html(data); } }); 
}   

</script>         
