    <tr>
        <td class="acct">'.$titleHtml.'</td>
        <td class="code"><strong>'.htmlspecialchars($grp['code'],ENT_QUOTES).'</strong></td>
        <td class="num">'.$items[0]['dr'].'</td>
        <td class="num">'.$items[0]['cr'].'</td>
    </tr>';
        $rowWeights[] = ($detailLine!='') ? 2 : 1;
        continue;
    }

    $acctLines=array();
    $codeLines=array();
    $drLines=array();
    $crLines=array();

    if($grp['has_detail']){
        $acctLines[]='<div class="cv-line"><strong>'.htmlspecialchars($grp['title'],ENT_QUOTES).'</strong></div>';
        $codeLines[]=htmlspecialchars($grp['code'],ENT_QUOTES);
