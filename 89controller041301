    ->order_by('seq','asc')
    ->get('dvd')
    ->result();

$rowItems=array();
$rowWeights=array();
$tdebit=0;
$tcredit=0;

$grouped=array();
$groupOrder=array();

foreach($rows as $row){
    $coacode='';
    $coaname='';

    if(intval($row->coa)>0){
        $coar=$this->db->where('id',intval($row->coa))->get('coa')->row();
        if($coar){
            $coacode=$this->format_coa_code($coar);
            if($coacode==''){
                $coacode=(string)$coar->code;
            }
            $coaname=(string)$coar->name;
        }
    }

    $title=trim($coaname);
    $part=trim((string)$row->particulars);

    if($title=='' && $part!=''){
        $title=$part;
        $part='';
    }
    if($title==''){
        $title='Entry '.$row->trntype;
    }

    $detailLine=trim((string)$part);

    $amt=floatval($row->amount);
    $dr='';
    $cr='';
    if($amt>=0){
        $tdebit+=$amt;
        $dr=number_format($amt,2);
    } else {
        $tcredit+=abs($amt);
        $cr=number_format(abs($amt),2);
    }

    $key=(intval($row->coa)>0) ? ('coa-'.intval($row->coa)) : ('row-'.$row->seq);

    if(!isset($grouped[$key])){
        $grouped[$key]=array(
            'title'=>$title,
            'code'=>$coacode,
            'items'=>array(),
            'has_detail'=>false
        );
        $groupOrder[]=$key;
    } else {
        if($grouped[$key]['title']=='' && $title!=''){ $grouped[$key]['title']=$title; }
        if($grouped[$key]['code']=='' && $coacode!=''){ $grouped[$key]['code']=$coacode; }
    }

    $grouped[$key]['items'][]=array(
        'detail'=>$detailLine,
        'dr'=>$dr,  
        'cr'=>$cr
    );
    if($detailLine!=''){
        $grouped[$key]['has_detail']=true;
    }
}

$renderLines=function($lines, $bold=false){
    $out='';
    foreach($lines as $line){
        $val=($line==='') ? '&nbsp;' : $line;
        if($bold){
            $out.='<div class="cv-line"><strong>'.$val.'</strong></div>';
        } else {
            $out.='<div class="cv-line">'.$val.'</div>';
        }
    }
    return $out;
};

foreach($groupOrder as $key){
    $grp=$grouped[$key];
