private function format_coa_code($coar) {
    if(!$coar){ return ''; }
    $parts=array(
        isset($coar->cd_acct1) ? trim((string)$coar->cd_acct1) : '',
        isset($coar->cd_acct2) ? trim((string)$coar->cd_acct2) : '',
        isset($coar->cd_acct3) ? trim((string)$coar->cd_acct3) : '',
        isset($coar->cd_acct4) ? trim((string)$coar->cd_acct4) : '',
        isset($coar->cd_acct5) ? trim((string)$coar->cd_acct5) : ''
    );
    // keep only non-empty parts so we don't produce trailing dashes
    $parts = array_filter($parts, function($p){ return $p !== ''; });
    if(empty($parts)){ return ''; }
    return implode('-', $parts);
}

