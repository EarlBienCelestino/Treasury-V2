$makePage=function($cap) use (&$idx,$total,$rowItems,$rowWeights,$blankRow){
    $rowsOut=array();
    $weight=0;
    while($idx < $total){
        $w=$rowWeights[$idx];
        if($weight + $w > $cap && $weight > 0){
            break;
        }
        $rowsOut[]=$rowItems[$idx];
        $weight+=$w;
        $idx++;
    }
    for($i=$weight; $i<$cap; $i++){
        $rowsOut[]=$blankRow;
    }
    return $rowsOut;
};

