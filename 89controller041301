                $codeLines[]=htmlspecialchars($grp['code'],ENT_QUOTES);
                $first=false;
            } else {
                $acctLines[]='<div class="cv-line acct-sub">&nbsp;</div>';
                $codeLines[]='';
            }
            $drLines[]=$it['dr'];
            $crLines[]=$it['cr'];
        }
    }

    $rowItems[]='
