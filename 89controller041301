        <td class="acct">'.implode('',$acctLines).'</td>
        <td class="code">'.$renderLines($codeLines, true).'</td>
        <td class="num">'.$renderLines($drLines).'</td>
        <td class="num">'.$renderLines($crLines).'</td>
