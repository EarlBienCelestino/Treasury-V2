    $prepared=(string)$this->db->where('id',intval($hdr->prepared_by))->get('users')->row('name');
}
if(property_exists($hdr,'noted_by') && intval($hdr->noted_by)>0){
    $noted=(string)$this->db->where('id',intval($hdr->noted_by))->get('users')->row('name');
}
if(property_exists($hdr,'verified_by') && intval($hdr->verified_by)>0){
