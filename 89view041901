function addrec() {
    // avoid creating another record if one is already open
    if (parseInt($("#id").val()) > 0) {
        return;
    }
    $.ajax({url:"<?=base_url('89/dashboard/addrec')?>",
            method:"POST",
            dataType:"json",
            data:{},
            success:function(data) { 
                var id=data.id;
                $("#id").val(id);

                edit_recx(id);  

            } }); 
}     

function edit_recx(id) {

    $.ajax({url:"<?=base_url('89/dashboard/edit_rec')?>",
            method:"POST",
            data:{id:id},
            success:function(data) { 
                $("#forms").empty(); 
                $("#form_entry").html(data); 
            } }); 
}   

