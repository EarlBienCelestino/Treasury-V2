<script>

var applyDate=0;
var discardDvDraftUrl = "<?=base_url('89/dashboard/discard_empty_draft')?>";

function cleanupEmptyDvDraft(options) {
    var draftId = parseInt($("#id").val() || 0, 10);
    var opts = options || {};
    if(draftId <= 0){
        if(typeof opts.onDone === "function"){ opts.onDone(); }
        return;
    }

    $.ajax({
        url: discardDvDraftUrl,
        method: "POST",
        async: opts.sync === true ? false : true,
        data: { id: draftId },
        complete: function(){
            if(opts.clearId !== false){
                $("#id").val(0);
            }
            if(typeof opts.onDone === "function"){
                opts.onDone();
            }
        }
    });
}

function cleanupEmptyDvDraftBeforeUnload() {
    var draftId = parseInt($("#id").val() || 0, 10);
    if(draftId <= 0){ return; }

    if(navigator.sendBeacon){
        var fd = new FormData();
        fd.append("id", draftId);
        navigator.sendBeacon(discardDvDraftUrl, fd);
        return;
    }

    cleanupEmptyDvDraft({ sync: true, clearId: false });
}

