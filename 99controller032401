function getamount($id){
$rr_saved = $this->db->where('id', $id)->get('ac_rfph')->row('rr');

if(!empty($rr_saved) && trim($rr_saved) != '' && trim($rr_saved) != '0') {
$rr_ids = array_filter(array_map('trim', explode(',', $rr_saved)));
$total = 0;
if(!empty($rr_ids)) {
    $rr_records = $this->db
        ->where_in('id', $rr_ids)
        ->get('rrh')->result_array();
    foreach($rr_records as $rr) {
        $total += floatval($rr['amt_rr']);
    }
}
$dat['amount'] = $total;
} else {
$dat['amount'] = $this->db
    ->select_sum('amount')
    ->where('id', $id)
    ->get('ac_rfpd')->row('amount');
}

$this->db->where('id', $id)->update('ac_rfph', $dat);
return $dat;
}

function fin() { 

$id=$_POST['id'];
$rs=$this->db->where('id',$id)->get('ac_rfph')->result();
$sw=0;
$dat['msg']='';$dat['sw']=0;
foreach($rs as $row){
    if(intval($row->request_by)>0){
        if(intval($row->dept)>0){
            if(intval($row->purpose)>0){
                if(intval($row->payment_type)>0){
                    $datex=explode('-',$row->date_needed);
                    if(intval($datex[0])>2022){
                        $dat['sw']=$sw=1; $dat['msg']='record finalized';
                    } else {$dat['msg']='please enter date needed (future date)';}
                } else {$dat['msg']='please select payment type';}
            } else {$dat['msg']='please select purpose';}
        } else {$dat['msg']='please select department';}
    } else {$dat['msg']='please select request_by';}
}   

if($sw==1){
    $datx['fin']=$_SESSION['user_id']; 
    $this->db->where('id',$id)->update('ac_rfph',$datx);       
}    

echo json_encode($dat);

}

