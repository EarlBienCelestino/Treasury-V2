function addrec() {

$uid=$_SESSION['user_id']; 
$loc=$_SESSION['location']; 

$mcode=$this->db 
    ->like('code', 'RFP-'.$loc.'-', 'after') 
    ->order_by('id','desc') 
    ->limit(1)->get('ac_rfph')->row('code');

    $pref='RFP';
    $series=1; 

    if(!empty($mcode)){
        $rcode=explode('-',$mcode); 
        if(count($rcode)==3){        
            $vseries=intval($rcode[2]);
        }
        else {
            $rcode=explode('RFP',$mcode); 
            $vseries=isset($rcode[1]) ? intval($rcode[1]) : 0;
        }
        $series = $vseries + 1;
    }

    $code=$pref.'-'.$loc.'-'.$series;        

    $dat['created_by']=$_SESSION['user_id']; 
    date_default_timezone_set("Asia/Manila");
    $xdate=$dat['date_']=date("Y-m-d H:i:s");
    $adate=explode(' ',$xdate);
    $vdate=$adate[1];
    $adate=explode(':',$vdate);
    $tr=1;
    if($adate[0]<=11){
        if(intval($adate[1])<=30){
            $tr=2;
        }
    }

    $dat['time_release']=$tr;  
    $dat['branch']=0;  
    $dat['code']=$code;    

$this->db->insert('ac_rfph',$dat);

$id=$this->db->insert_id();
if(empty($id)) {
    $id=$this->db->where('code',$dat['code'])->get('ac_rfph')->row('id');
}

echo json_encode(array('id'=>$id));

}

