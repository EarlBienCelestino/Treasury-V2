$dat['request_by']=$uid;
date_default_timezone_set("Asia/Manila");
$xdate=$dat['date_']=date("Y-m-d H:i:s");
$adate=explode(' ',$xdate);
$vdate=$adate[1];
$adate=explode(':',$vdate);
$tr=1;
if($adate[0]<=11){
    if(intval($adate[1])<=30){
        $tr=2;
    }
}

$dat['r_type']=$rt;  
$dat['time_release']=$tr;  
$dat['branch']=0;  
$dat['code']=$code;

$ok = $this->db->insert('ac_rfph',$dat);

$id=$this->db->insert_id();
if(empty($id)) {
    $id=$this->db->where('code',$dat['code'])->get('ac_rfph')->row('id');
}

if($ok && !empty($id)){
    echo json_encode(array('id'=>$id));
} else {
    echo json_encode(array('id'=>0, 'msg'=>'Unable to add new RFP'));
}

}

