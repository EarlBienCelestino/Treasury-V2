function addrec() {

$rt = intval($this->input->post('rt'));
$uid=$_SESSION['user_id']; 
$loc=$_SESSION['location']; 

if($rt <= 0){
    echo json_encode(array('id'=>0, 'msg'=>'Invalid RFP Type'));
    return;
}

$mcode=$this->db 
    ->like('code', 'RFP-'.$loc.'-', 'after') 
    ->order_by('id','desc') 
    ->limit(1)->get('ac_rfph')->row('code');

$pref='RFP';
$series=1; 

if(!empty($mcode)){
    $rcode=explode('-',$mcode); 
    if(count($rcode)==3){        
        $vseries=intval($rcode[2]);
    }
    else {
        $rcode=explode('RFP',$mcode); 
        $vseries=isset($rcode[1]) ? intval($rcode[1]) : 0;
    }
    $series = $vseries + 1;
}

