function getamount($id) {
    $total = $this->_calc_total($id);
    $this->db->where('id', $id)->update('ac_rfph', ['amount' => $total]);
    return ['amount' => $total];
}
    
private function _calc_total($id) {
    $total = 0;

    $rr_lines = $this->db->where('id', $id)->where('sw', 1)->get('ac_rfpd')->result_array();
    foreach ($rr_lines as $line) {
        $total += floatval($line['amount']);
    }

    $po_lines = $this->db->where('id', $id)->where('sw', 2)->get('ac_rfpd')->result_array();
    foreach ($po_lines as $line) {
        $total += floatval($line['amount']);
    }

    $rr_saved    = $this->db->where('id', $id)->get('ac_rfph')->row('rr');
    $saved_ids   = (!empty($rr_saved) && trim($rr_saved) !== '' && trim($rr_saved) !== '0')
        ? array_filter(array_map('trim', explode(',', $rr_saved))) : [];
    $counted_ids = array_column($rr_lines, 'trn_id');

    foreach ($saved_ids as $rr_id) {
        if (in_array($rr_id, $counted_ids)) continue;
        $amt = $this->db->where('id', $rr_id)->get('rrh')->row('amt_rr');
        if ($amt) $total += floatval($amt);
    }

    $liq_id = intval($this->db->where('id', $id)->get('ac_rfph')->row('liquidation'));
    if($liq_id > 0){
        $liq_rows = $this->db->where('id', $liq_id)->get('liqd')->result_array();
        foreach($liq_rows as $lr){
            $total += floatval($lr['amount']);
        }
    }

    $liq_lines = $this->db->where('id', $id)->where('sw', 32)->get('ac_rfpd')->result_array();
foreach($liq_lines as $line){
    $liq_h = $this->db->where('id', $line['trn_id'])->get('liqh')->row('amount');
    if($liq_h) $total += floatval($liq_h);
}

$gl_lines = $this->db->where('id', $id)->where('sw', 5)->get('ac_rfpd')->result_array();
foreach($gl_lines as $line){
    if(isset($line['trn']) && in_array(intval($line['trn']), array(32,42))) continue;
    $total += floatval($line['amount']);
}

$printed_exp_ids = array();

$exp_lines = $this->db
    ->where('id', $id)
    ->where('sw', 42)
    ->get('ac_rfpd')
    ->result_array();

foreach($exp_lines as $line){
    $exp_id = intval($line['trn_id']);
    if($exp_id <= 0) continue;
    if(in_array($exp_id, $printed_exp_ids)) continue;

    $exp_amt = $this->db->where('id', $exp_id)->get('dsr_exph')->row('tamt');
    if($exp_amt){
        $total += floatval($exp_amt);
    }

    $printed_exp_ids[] = $exp_id;
}

return $total;
}
    
function fin() { 

$id = intval($this->input->post('id'));
$dat = array('msg'=>'', 'sw'=>0);

if($id <= 0){
    $dat['msg'] = 'invalid record';
    echo json_encode($dat);
    return;
}

$row = $this->db->where('id',$id)->get('ac_rfph')->row();

if(empty($row)){
    $dat['msg'] = 'record not found';
    echo json_encode($dat);
    return;
}

if(intval($row->purpose) <= 0){
    $dat['msg']='please select purpose';
    echo json_encode($dat);
    return;
}

if(intval($row->payment_type) <= 0){
    $dat['msg']='please select payment type';
    echo json_encode($dat);
    return;
}

$total = $this->_calc_total($id);

$this->db->where('id', $id)->update('ac_rfph', array(
    'amount' => $total,
    'fin'    => $this->session->userdata('user_id')
));

$dat['sw']=1;
$dat['msg']='record finalized';

echo json_encode($dat);

}

