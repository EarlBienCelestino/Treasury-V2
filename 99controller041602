function close_save() {
    $id   = intval($this->input->post('id'));
    $vals = $this->input->post('vals');

    $uid = $_SESSION['user_id'];
    $ur  = $this->db->where('userid',$uid)->get('scm_user')->row('User_rights');

    if($id <= 0){
        echo json_encode(array('sw'=>0, 'msg'=>'Invalid record'));
        return;
    }

    $fin = $this->db->where('id',$id)->get('ac_rfph')->row('fin');

    $allow = 0;
    if($fin==0) { $allow=1; }
    if($ur==4 or $ur==8) { $allow=1; }

    if($allow==0){
        echo json_encode(array('sw'=>0, 'msg'=>'Record already finalized'));
        return;
    }

    if(!is_array($vals)){
        echo json_encode(array('sw'=>0, 'msg'=>'No data received'));
        return;
    }

    $flds = $this->db->list_fields('ac_rfph');
    $skip = array('ca','rramt','prramt','brramt','damt','seq','del_seq');

    $dat = array();
    $cur_time_release = intval($this->db->where('id',$id)->get('ac_rfph')->row('time_release'));

    foreach($vals as $k => $v){
        if(in_array($k, $skip)) { continue; }
        if(!in_array($k, $flds)) { continue; }

        if(is_array($v)){
            $v = implode(',', $v);
        }

        if($k == 'time_release'){
            $v = intval($v);
            $dat[$k] = ($v > 0 ? $v : $cur_time_release);
        } else {
