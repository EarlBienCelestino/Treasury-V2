    function addrec() {
        date_default_timezone_set('Asia/Manila');
        $uid = $this->session->userdata('user_id');
        $loc = $this->session->userdata('location');

        $mcode = $this->db
            ->like('code', 'RFP-' . $loc . '-', 'after')
            ->order_by('id', 'desc')
            ->limit(1)
            ->get('ac_rfph')
            ->row('code');

        $series = 1;
        if (!empty($mcode)) {
            $parts = explode('-', $mcode);
            $series = (count($parts) >= 3 ? intval($parts[2]) : 0) + 1;
        }

        $code  = 'RFP-' . $loc . '-' . $series;
        $xdate = date('Y-m-d H:i:s');

        $dat = [
            'created_by'   => $uid,
            'request_by'   => $uid,
            'date_'        => $xdate,
            'branch'       => 0,
            'code'         => $code,
            'time_release' => $this->_time_release($xdate),
        ];

        $this->db->insert('ac_rfph', $dat);
        $id = $this->db->insert_id();
        if (empty($id)) {
            $id = $this->db->where('code', $code)->get('ac_rfph')->row('id');
        }

        echo json_encode(['id' => $id]);
    }

    private function _time_release($datetime) {
        $parts = explode(' ', $datetime);
        $time  = explode(':', $parts[1]);
        return ($time[0] <= 11 && intval($time[1]) <= 30) ? 2 : 1;
    }

    function fsave() {
        $tmp = $this->input->post('datas');
        $id  = $tmp[0];
        $fld = $tmp[1];
        $val = $this->input->post('val') !== null ? $this->input->post('val') : (isset($tmp[2]) ? $tmp[2] : '');

        $uid = $this->session->userdata('user_id');
        $ur  = $this->db->where('userid', $uid)->get('scm_user')->row('User_rights');
        $fin = $this->db->where('id', $id)->get('ac_rfph')->row('fin');

        // Allow save if not finalized, or if admin-level user
        if ($fin == 0 || $ur == 4 || $ur == 8) {
            $this->db->where('id', $id)->update('ac_rfph', [$fld => $val]);
        }

        echo json_encode([$fld => $val]);
    }

    function dsave() {
        $tmp = $this->input->post('datas');
        $id  = intval($tmp[0]);
        $seq = intval($tmp[1]);
        $sw  = intval($tmp[2]);
        $fin = $this->db->where('id', $id)->get('ac_rfph')->row('fin');

        if ($fin != 0) {
            echo json_encode(['error' => 'Record is finalized']);
            return;
        }

        $dat = [
            'id'       => $id,
            'sw'       => $sw,
            'trn_type' => $sw,
            'trn_id'   => intval($tmp[3]),
            'amount'   => floatval($tmp[4]),
            'balance'  => floatval($tmp[5]),
        ];

        if ($seq == 0) {
            $this->db->insert('ac_rfpd', $dat);
            $dat['seq'] = $this->db->insert_id();
        } else {
            $this->db->where('seq', $seq)->update('ac_rfpd', $dat);
            $dat['seq'] = $seq;
        }

        echo json_encode($dat);
    }

    function ddel() {
        $tmp = $this->input->post('datas');
        $id  = intval($tmp[0]);
        $seq = intval($tmp[1]);
        $fin = $this->db->where('id', $id)->get('ac_rfph')->row('fin');

        if ($fin == 0) {
            $this->db->where('seq', $seq)->delete('ac_rfpd');
        }
    }

    // ─────────────────────────────────────────────
    // WORKFLOW
    // ─────────────────────────────────────────────

    function fin() {
        $id  = $this->input->post('id');
        $row = $this->db->where('id', $id)->get('ac_rfph')->row();

        $dat = ['sw' => 0, 'msg' => ''];

        if (intval($row->purpose) > 0) {
            if (intval($row->payment_type) > 0) {
                $datex = explode('-', $row->date_needed);
                if (intval($datex[0]) > 2022) {
                    // Recalculate amount before finalizing
                    $total = $this->_calc_total($id);
                    $this->db->where('id', $id)->update('ac_rfph', ['amount' => $total]);

                    $this->db->where('id', $id)->update('ac_rfph', [
                        'fin' => $this->session->userdata('user_id')
                    ]);
                    $dat = ['sw' => 1, 'msg' => 'Record finalized'];
                } else {
                    $dat['msg'] = 'Please enter a valid Date Needed (future date)';
                }
            } else {
                $dat['msg'] = 'Please select a payment type';
            }
        } else {
            $dat['msg'] = 'Please select a purpose';
        }

        echo json_encode($dat);
    }

    function unfin() {
        $id = $this->input->post('id');
        $this->db->where('id', $id)->update('ac_rfph', ['fin' => 0]);
    }

