        $dvappby_id    = intval($row['approved_by']);
        $dvappby_nm    = $this->db->where('id', $dvappby_id)->get('users')->row('name') ?: '';
        $prepared_nm   = $prepared_id
            ? ($this->db->where('id', $prepared_id)->get('users')->row('name') ?: '')
            : ($this->db->where('id', $row['created_by'])->get('users')->row('name') ?: '');
        $req_unit_nm   = $this->db->where('id', $row['created_by'])->get('users')->row('name') ?: '';
        $req_head_nm   = (!empty($row['request_by']) && intval($row['request_by']) > 0)
            ? ($this->db->where('id', $row['request_by'])->get('users')->row('name') ?: '')
            : '';

        // Dates
        $date_created = (!empty($row['date_']) && substr($row['date_'], 0, 4) > '2000')
            ? date_format(date_create($row['date_']), 'F d, Y') : '';
        $date_needed  = (!empty($row['date_needed']) && substr($row['date_needed'], 0, 4) > '2000')
            ? date_format(date_create($row['date_needed']), 'F d, Y') : '';

        // ── Build detail entries and total ───────────────────
        // Source 1: RR lines from ac_rfpd sw=1 (primary, from info tab)
        $all_entries = [];
        $tamt        = 0;

        $rr_lines = $this->db->where('id', $id)->where('sw', 1)
            ->order_by('seq', 'asc')->get('ac_rfpd')->result_array();
        foreach ($rr_lines as $line) {
            $rr = $this->db->where('id', $line['trn_id'])->get('rrh')->row_array();
            if (!$rr) continue;
            $rr_date = (!empty($rr['date_']) && substr($rr['date_'], 0, 4) != '0000')
                ? date('m/d/Y', strtotime($rr['date_'])) : '';
            $amt      = floatval($line['amount']);
            $tamt    += $amt;
            $all_entries[] = [
                'type'   => 'RR',
                'code'   => $rr['code'],
                'date'   => $rr_date,
                'amount' => $amt,
            ];
        }

        // Source 2: RRs from ac_rfph.rr comma field NOT already in ac_rfpd sw=1
        $rr_saved    = $row['rr'];
        $saved_ids   = (!empty($rr_saved) && trim($rr_saved) !== '' && trim($rr_saved) !== '0')
            ? array_filter(array_map('trim', explode(',', $rr_saved)))
            : [];
        $counted_ids = array_column($rr_lines, 'trn_id');

        if (!empty($saved_ids)) {
            $extra_rrs = $this->db->where_in('id', $saved_ids)
                ->order_by('date_', 'asc')->order_by('code', 'asc')
                ->get('rrh')->result_array();
            foreach ($extra_rrs as $rr) {
                if (in_array($rr['id'], $counted_ids)) continue;
                $rr_date = (!empty($rr['date_']) && substr($rr['date_'], 0, 4) != '0000')
                    ? date('m/d/Y', strtotime($rr['date_'])) : '';
                $amt      = floatval($rr['amt_rr']);
                $tamt    += $amt;
                $all_entries[] = [
                    'type'   => 'RR',
                    'code'   => $rr['code'],
                    'date'   => $rr_date,
                    'amount' => $amt,
                ];
            }
        }

        // Source 3: PO lines from ac_rfpd sw=2
        $po_lines = $this->db->where('id', $id)->where('sw', 2)
            ->order_by('seq', 'asc')->get('ac_rfpd')->result_array();
        foreach ($po_lines as $line) {
