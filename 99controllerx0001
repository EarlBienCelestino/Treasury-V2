    // ─────────────────────────────────────────────
    // AMOUNT CALCULATION
    // Unified: reads ac_rfpd sw=1 (RR lines) + sw=2 (PO lines).
    // Also adds any RRs linked via ac_rfph.rr comma field that are
    // NOT already represented in ac_rfpd sw=1.
    // This keeps both storage methods in sync.
    // ─────────────────────────────────────────────

    private function _calc_total($id) {
        $total = 0;

        // 1. RR detail lines stored in ac_rfpd (sw=1) — primary RR storage from info(1) tab
        $rr_lines = $this->db->where('id', $id)->where('sw', 1)->get('ac_rfpd')->result_array();
        foreach ($rr_lines as $line) {
            $total += floatval($line['amount']);
        }

        // 2. PO detail lines stored in ac_rfpd (sw=2)
        $po_lines = $this->db->where('id', $id)->where('sw', 2)->get('ac_rfpd')->result_array();
        foreach ($po_lines as $line) {
            $total += floatval($line['amount']);
        }

        // 3. RRs linked via ac_rfph.rr comma field (from rr_tab Select2) that are
        //    NOT already in ac_rfpd sw=1 — avoids double-counting
        $rr_saved   = $this->db->where('id', $id)->get('ac_rfph')->row('rr');
        $saved_ids  = (!empty($rr_saved) && trim($rr_saved) !== '' && trim($rr_saved) !== '0')
            ? array_filter(array_map('trim', explode(',', $rr_saved)))
            : [];

        // Collect trn_ids already counted via ac_rfpd sw=1
        $counted_trn_ids = array_column($rr_lines, 'trn_id');

        foreach ($saved_ids as $rr_id) {
            if (in_array($rr_id, $counted_trn_ids)) {
                continue; // already counted
            }
            $amt = $this->db->where('id', $rr_id)->get('rrh')->row('amt_rr');
            if ($amt) {
                $total += floatval($amt);
            }
        }

        return $total;
    }

    function getamount($id) {
        $total = $this->_calc_total($id);
        $this->db->where('id', $id)->update('ac_rfph', ['amount' => $total]);
        return ['amount' => $total];
    }

    function recalc_rr_amount() {
        $id    = $this->input->post('id');
        $total = $this->_calc_total($id);
        $this->db->where('id', $id)->update('ac_rfph', ['amount' => $total]);
        echo json_encode(['amount' => number_format($total, 2)]);
    }

