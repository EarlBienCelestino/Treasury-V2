    function getrr() {
        $id  = $this->input->post('id');
        $row = $this->db->where('id', $id)
            ->where('CAST(amt_rr AS DECIMAL) >', 10)
            ->get('rrh')->row_array();

        $dat = ['rramt' => 0, 'prramt' => 0, 'brramt' => 0];
        if ($row) {
            $dat['rramt']  = floatval($row['amt_rr']);
            $dat['prramt'] = floatval($row['amt_paid']);
            $dat['brramt'] = $dat['rramt'] - floatval($row['amt_ret']) - $dat['prramt'];
        }
        echo json_encode($dat);
    }

    function getpo() {
        $id  = $this->input->post('id');
        $row = $this->db->where('id', $id)
            ->where('CAST(amt_po AS DECIMAL) >', 10)
            ->get('poh')->row_array();

        $dat = ['rramt' => 0, 'prramt' => 0, 'brramt' => 0];
        if ($row) {
            $dat['rramt']  = floatval($row['amt_po']);
            $dat['brramt'] = $dat['rramt'];
        }
        echo json_encode($dat);
    }

    function mf($sw) {
        $id = $this->input->post('id');
        $xs = $this->input->post('searchTerm');

        $data   = [['id' => 0, 'text' => 'select none']];

        if ($sw === 'rr') {
            $rs = $this->db
                ->like('concat(code,date_)', $xs)
                ->where('CAST((amt_rr - amt_paid) AS DECIMAL) >', 10)
                ->order_by('code')->limit(10)
                ->get('rrh')->result_array();

            foreach ($rs as $row) {
                $already = $this->db->where('id', $id)->where('sw', 1)
                    ->where('trn_id', $row['id'])->get('ac_rfpd')->result();
                if (count($already) == 0) {
                    $bal = floatval($row['amt_rr']) - floatval($row['amt_ret']) - floatval($row['amt_paid']);
                    if ($bal > 0) {
                        $data[] = [
                            'id'   => $row['id'],
                            'text' => $row['code'] . ' - ' . $row['date_']
                                    . ' Amt ' . $row['amt_rr']
                                    . ' Ret '  . $row['amt_ret']
                                    . ' Paid ' . $row['amt_paid'],
                        ];
                    }
                }
            }
        }

        if ($sw === 'po') {
            $rs = $this->db
                ->like('concat(code,date_)', $xs)
                ->order_by('code')->limit(10)
                ->get('poh')->result_array();

            foreach ($rs as $row) {
                $data[] = [
                    'id'   => $row['id'],
                    'text' => $row['code'] . ' - ' . $row['date_'] . ' Amt ' . $row['amt_po'],
                ];
            }
        }

        echo json_encode($data);
    }

