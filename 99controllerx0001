    function print($id) {
        $row = $this->db->where('id', $id)->get('ac_rfph')->row_array();
        if (!$row) { echo 'Record not found.'; return; }

        $purpose_arr = explode(',', ',Merchandise,Raw Mat,Down Payment,Mobilization,Travel,Utilities,Professional Fee,Asset,Legal Fees,Repaired Maintenance,Trucking & Delivery,Supplies,Others');
