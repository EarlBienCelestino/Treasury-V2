<script>

function exits() {
    var datas = [
    $("#ds").val(),
    $("#de").val(),
    $("#rt").val() || 0
];
    $.ajax({
        url: "<?=base_url('99/dashboard/list')?>",
        method: "POST",
        data: { datas: datas },
        success: function(data) {  
            $("#forms").empty();
            $("#forms").html(data);
            $("#xsearch").show();
            $("#rfp-row").removeClass("rfp-edit-mode");
        } 
    }); 
}

function edit_recs(id) {
    $("#rfp-row").addClass("rfp-edit-mode");
    $("#xsearch").hide();
    $("#filters-col").hide();

    $.ajax({
        url: "<?=base_url("99/dashboard/edit_rec")?>",
        method: "POST", 
        data: { id: id },
        success: function(data) { 
            $("#forms").html(data); 
        } 
    });  
} 

function addrec() { 
    if($("#rt").val() !== ""){
    $.ajax({
        url: "<?=base_url('99/dashboard/addrec')?>",
        method: "POST",
        dataType: "json",
        data: {rt:$("#rt").val()},
        success: function(data) { 
    if(data.id > 0){
        edit_recs(data.id); 
    } else {
        alert("Invalid RFP Type");
    }
}  
    });  
    }else {alert("please select RFP Type");}
}

function list() {
    var datas = [
    $("#ds").val(),
    $("#de").val(),
    $("#rt").val() || 0
];
    $.ajax({
        url: "<?=base_url('99/dashboard/list')?>",
        method: "POST",
        data: { datas: datas },
        success: function(data) { 
            $("#forms-col").empty(); 
            $("#forms-col").html(data);
            
            $("#rfp-row").show();
            
            $("#forms").empty();
            //$("#rfp-row").removeClass("rfp-edit-mode");
        } 
    }); 
}

// Search by keyword
function list2() {
    var qs = $("#qs").val();
    $.ajax({
        url: "<?=base_url('99/dashboard/list2')?>",
        method: "POST",
        data: { qs: qs },
        success: function(data) {  
            $("#forms").empty();
            $("#forms").html(data);
            $("#rfp-row").show();
            //$("#xsearch").show();
            //$("#rfp-row").removeClass("rfp-edit-mode");
        } 
    }); 
} 

// Load list on page ready
$(document).ready(function() { 
    $("#xsearch").show();
    $("#rfp-row").removeClass("rfp-edit-mode");
    list();
}); 

</script>
