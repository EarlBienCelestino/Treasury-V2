<script>

function exits() {
    var datas = [
        $("#ds").val(),
        $("#de").val(),
        $("#rt").val() || 0
    ];

    $.ajax({
        url: "<?=base_url('99/dashboard/list')?>",
        method: "POST",
        data: { datas: datas },
        success: function(data) {
            $("#forms").empty();
            $("#forms-col").empty().html(data);
            $("#xsearch").show();
            $("#rfp-row").show();
        }
    });
}
function edit_recs(id) {
    $("#rfp-row").hide(); 

    $.ajax({
        url: "<?=base_url("99/dashboard/edit_rec")?>",
        method: "POST", 
        data: { id: id },
        success: function(data) { 
            $("#forms").html(data); 
        } 
    });  
}
function addrec() { 
    var rt = $("#rt").val();

    if(rt !== ""){
        $.ajax({
            url: "<?=base_url('99/dashboard/addrec')?>",
            method: "POST",
            dataType: "json",
            data: { rt: rt },
            success: function(data) { 
                if(data && parseInt(data.id) > 0){
                    edit_recs(data.id); 
                } else {
                    alert(data && data.msg ? data.msg : "Unable to add new RFP.");
                }
            },
            error: function() {
                alert("Unable to add new RFP.");
            }
        });  
    } else {
        alert("please select RFP Type");
    }
}

function list() {
    var ds = $("#ds").val();
    var de = $("#de").val();
    var rt = $("#rt").val() || 0;

    if(ds === "" || de === ""){
        alert("Please select Date Start and Date End.");
        return;
    }

    $.ajax({
        url: "<?=base_url('99/dashboard/list')?>",
        method: "POST",
        data: {
            ds: ds,
            de: de,
            rt: rt
        },
        success: function(data) { 
            $("#forms-col").html(data);
            $("#forms").empty();
            $("#rfp-row").show();
        },
        error: function() {
            alert("Unable to load RFP list.");
        }
    }); 
}
function list2() {
    var qs = $("#qs").val();
    $.ajax({
        url: "<?=base_url('99/dashboard/list2')?>",
        method: "POST",
        data: { qs: qs },
        success: function(data) {  
            $("#forms").empty();
            $("#forms").html(data);
            $("#rfp-row").show();
            //$("#xsearch").show();
            //$("#rfp-row").removeClass("rfp-edit-mode");
        } 
    }); 
} 

// Load list on page ready
$(document).ready(function() { 
    $("#xsearch").show();
    $("#rfp-row").removeClass("rfp-edit-mode");
    list();
}); 

</script>
