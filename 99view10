<script>

function exits() {
    var datas = [$("#ds").val(), $("#de").val(), $("#rt").val()];
    $.ajax({
        url: "<?=base_url('99/dashboard/list')?>",
        method: "POST",
        data: { datas: datas },
        success: function(data) {  
            $("#forms").empty();
            $("#forms").html(data);
            $("#xsearch").show();
        } 
    }); 
}

function edit_recs(id) {
    $.ajax({
        url: "<?=base_url("99/dashboard/edit_rec")?>",
        method: "POST", 
        data: { id: id },
        success: function(data) { 
            $("#xsearch").hide();  
            $("#forms").html(data); 
        } 
    });  
} 

// Create new blank record then open its edit form
function addrec() { 
    if($("#rt").val()>0){
    $.ajax({
        url: "<?=base_url('99/dashboard/addrec')?>",
        method: "POST",
        dataType: "json",
        data: {rt:$("#rt").val()},
        success: function(data) { 
            edit_recs(data.id); 
        } 
    });  
    }else {alert("please select RFP Type");}
}

function list() {
    var datas = [$("#ds").val(), $("#de").val(), $("#rt").val()];
    $.ajax({
        url: "<?=base_url('99/dashboard/list')?>",
        method: "POST",
        data: { datas: datas },
        success: function(data) { 
            $("#forms").empty(); 
            $("#forms").html(data);
            $("#xsearch").show();
        } 
    }); 
}

// Search by keyword
function list2() {
    var qs = $("#qs").val();
    $.ajax({
        url: "<?=base_url('99/dashboard/list2')?>",
        method: "POST",
        data: { qs: qs },
        success: function(data) {  
            $("#forms").empty();
            $("#forms").html(data);
            $("#xsearch").show();
        } 
    }); 
} 

// Load list on page ready
$(document).ready(function() { 
    $("#xsearch").show();
    list();
}); 

</script>
