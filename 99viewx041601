<script>

var rfpListTimer = null;
var discardRfpDraftUrl = "<?=base_url('99/dashboard/discard_empty_draft')?>";
window.__rfpDraftId = 0;

function cleanupEmptyRfpDraft(options) {
    var draftId = parseInt(window.__rfpDraftId || 0, 10);
    var opts = options || {};
    if(draftId <= 0){
        if(typeof opts.onDone === "function"){ opts.onDone(); }
        return;
    }

    $.ajax({
        url: discardRfpDraftUrl,
        method: "POST",
        async: opts.sync === true ? false : true,
        data: { id: draftId },
        complete: function(){
            window.__rfpDraftId = 0;
            if(typeof opts.onDone === "function"){
                opts.onDone();
            }
        }
    });
}

function cleanupEmptyRfpDraftBeforeUnload() {
    var draftId = parseInt(window.__rfpDraftId || 0, 10);
    if(draftId <= 0){ return; }

    if(navigator.sendBeacon){
        var fd = new FormData();
        fd.append("id", draftId);
        navigator.sendBeacon(discardRfpDraftUrl, fd);
        return;
    }

    cleanupEmptyRfpDraft({ sync: true });
}

function queueList() {
    clearTimeout(rfpListTimer);
    rfpListTimer = setTimeout(function() {
        list();
    }, 250);
}

function exits() {
    var datas = [
        $("#ds").val(),
        $("#de").val(),
        $("#qs").val() || ""
    ];
    cleanupEmptyRfpDraft({
        onDone: function(){
            $.ajax({
                url: "<?=base_url('99/dashboard/list')?>",
                method: "POST",
                data: { datas: datas },
                success: function(data) {
                    $("#forms").empty();
                    $("#forms-col").empty().html(data);
                    $("#xsearch").show();
                    $("#rfp-row").show();
                }
            });
        }
    });
}

function edit_recs(id) {
    window.__rfpDraftId = parseInt(id || 0, 10) || 0;
    $("#rfp-row").hide(); 

    $.ajax({
        url: "<?=base_url("99/dashboard/edit_rec")?>",
        method: "POST", 
        data: { id: id },
        success: function(data) { 
            $("#forms").html(data); 
        } 
    });  
}

function addrec() { 
    $.ajax({
        url: "<?=base_url('99/dashboard/addrec')?>",
        method: "POST",
        dataType: "json",
        data: {},
        success: function(data) { 
            if(data && parseInt(data.id) > 0){
                window.__rfpDraftId = parseInt(data.id, 10) || 0;
                edit_recs(data.id); 
            } else {
                alert(data && data.msg ? data.msg : "Unable to add new RFP.");
            }
        },
        error: function() {
            alert("Unable to add new RFP.");
        }
    });  
}

function list() {
    var datas = [
        $("#ds").val(),
        $("#de").val(),
        $("#qs").val() || ""
    ];
    cleanupEmptyRfpDraft({
        onDone: function(){
            $.ajax({
                url: "<?=base_url('99/dashboard/list')?>",
                method: "POST",
                data: { datas: datas },
                success: function(data) { 
                    $("#forms-col").empty().html(data);
                    $("#forms").empty();
                    $("#rfp-row").show();
                },
                error: function() {
                    alert("Unable to load RFP list.");
                }
            });
        }
    }); 
}
function list2() {
    list();
} 

// Load list on page ready
$(document).ready(function() { 
    $("#xsearch").show();
    $("#rfp-row").removeClass("rfp-edit-mode");
    list();
}); 

window.addEventListener("beforeunload", cleanupEmptyRfpDraftBeforeUnload);

</script>
